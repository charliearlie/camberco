---
export const prerender = false;
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Overview">
  <main style="max-width: 1100px; margin: 0 auto; padding: var(--space-8) var(--space-6);">
    <h1
      style="
        font-family: var(--font-mono);
        font-size: 20px;
        font-weight: 700;
        color: var(--color-green-500);
        margin: 0 0 var(--space-6) 0;
      "
    >
      $ camber admin --overview
    </h1>

    <!-- Error -->
    <div
      id="ov-error"
      style="
        display: none;
        padding: var(--space-2) var(--space-3);
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.3);
        border-radius: var(--radius-sm);
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--color-error);
        margin-bottom: var(--space-4);
      "
    >
    </div>

    <!-- KPI tiles -->
    <section aria-label="Key metrics">
      <div id="kpi-grid" class="kpi-grid">
        <div class="kpi-tile" aria-hidden="true"><div class="kpi-value">–</div><div class="kpi-label">loading…</div></div>
      </div>
    </section>

    <!-- Two-column activity -->
    <div class="ov-columns">
      <section class="ov-panel" aria-label="Recent enquiries">
        <div class="ov-panel-head">
          <h2 class="ov-panel-title">recent enquiries</h2>
          <a href="/admin/enquiries" class="ov-panel-link">all →</a>
        </div>
        <div id="recent-enquiries" class="ov-list">
          <div class="ov-loading">loading…</div>
        </div>
      </section>

      <section class="ov-panel" aria-label="Open projects">
        <div class="ov-panel-head">
          <h2 class="ov-panel-title">open projects</h2>
          <a href="/admin/projects" class="ov-panel-link">all →</a>
        </div>
        <div id="recent-projects" class="ov-list">
          <div class="ov-loading">loading…</div>
        </div>
      </section>
    </div>

    <!-- Quick links -->
    <nav class="ov-quicklinks" aria-label="Sections">
      <a href="/admin/clients" class="ov-quicklink">$ clients</a>
      <a href="/admin/projects" class="ov-quicklink">$ projects</a>
      <a href="/admin/enquiries" class="ov-quicklink">$ enquiries</a>
      <a href="/admin/blog" class="ov-quicklink">$ blog</a>
    </nav>
  </main>
</AdminLayout>

<script>
  import { supabase } from '../../lib/supabase';
  import { penceToGBP } from '../../lib/crm';

  interface Kpis {
    newEnquiries: number;
    activeClients: number;
    openProjects: number;
    openPipelinePence: number;
    nonGbpOpenCount: number;
  }
  interface RecentEnquiry {
    id: string;
    name: string;
    email: string;
    company: string | null;
    service: string;
    status: string;
    created_at: string;
    client_id: string | null;
  }
  interface RecentProject {
    id: string;
    name: string;
    status: string;
    value_pence: number | null;
    currency: string;
    due_date: string | null;
    created_at: string;
    client: { id: string; name: string } | null;
  }

  const errorEl = document.getElementById('ov-error') as HTMLDivElement;
  const kpiGrid = document.getElementById('kpi-grid') as HTMLDivElement;
  const recentEnqEl = document.getElementById('recent-enquiries') as HTMLDivElement;
  const recentProjEl = document.getElementById('recent-projects') as HTMLDivElement;

  async function getToken(): Promise<string | null> {
    const { data: { session } } = await supabase.auth.getSession();
    return session?.access_token ?? null;
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  const statusColors: Record<string, string> = {
    new: 'var(--color-green-500)', contacted: 'var(--color-warning)', booked: 'var(--color-pink-500)', closed: 'var(--color-text-muted)',
    lead: 'var(--color-warning)', active: 'var(--color-green-500)', past: 'var(--color-text-muted)', archived: 'var(--color-text-muted)',
    proposal: 'var(--color-pink-500)', on_hold: 'var(--color-warning)', completed: 'var(--color-green-400)', cancelled: 'var(--color-error)',
  };

  function statusBadge(status: string): string {
    const color = statusColors[status] || 'var(--color-text-muted)';
    const label = escapeHtml(status.replace(/_/g, ' '));
    return `<span style="display:inline-block;padding:2px 10px;background:color-mix(in srgb, ${color} 13%, transparent);color:${color};font-family:var(--font-mono);font-size:11px;font-weight:600;border-radius:9999px;border:1px solid color-mix(in srgb, ${color} 30%, transparent);letter-spacing:0.02em;">${label}</span>`;
  }

  function kpiTile(href: string, value: string, label: string, note = ''): string {
    return `<a class="kpi-tile" href="${href}"><div class="kpi-value">${escapeHtml(value)}</div><div class="kpi-label">${escapeHtml(label)}</div>${note ? `<div class="kpi-note">${escapeHtml(note)}</div>` : ''}</a>`;
  }

  function renderKpis(k: Kpis) {
    const note = k.nonGbpOpenCount > 0
      ? `${k.nonGbpOpenCount} non-GBP project${k.nonGbpOpenCount === 1 ? '' : 's'} excluded`
      : '';
    kpiGrid.innerHTML = [
      kpiTile('/admin/enquiries', String(k.newEnquiries), 'new enquiries'),
      kpiTile('/admin/clients', String(k.activeClients), 'active clients'),
      kpiTile('/admin/projects', String(k.openProjects), 'open projects'),
      kpiTile('/admin/projects', penceToGBP(k.openPipelinePence), 'open pipeline', note),
    ].join('');
  }

  function convertedBadge(): string {
    const color = 'var(--color-green-400)';
    return `<span title="Converted to a client" style="display:inline-block;padding:2px 8px;background:color-mix(in srgb, ${color} 13%, transparent);color:${color};font-family:var(--font-mono);font-size:10px;font-weight:600;border-radius:9999px;border:1px solid color-mix(in srgb, ${color} 30%, transparent);">converted</span>`;
  }

  function renderRecentEnquiries(items: RecentEnquiry[]) {
    if (items.length === 0) {
      recentEnqEl.innerHTML = `<div class="ov-empty">no enquiries yet</div>`;
      return;
    }
    recentEnqEl.innerHTML = items
      .map(
        (e) => `
        <a class="ov-row" href="/admin/enquiries">
          <span class="ov-row-main">
            <span class="ov-row-title">${escapeHtml(e.name)}</span>
            <span class="ov-row-sub">${escapeHtml(e.service || '—')}</span>
          </span>
          <span class="ov-row-meta">
            ${e.client_id ? convertedBadge() : statusBadge(e.status)}
            <span class="ov-row-date">${formatDate(e.created_at)}</span>
          </span>
        </a>`,
      )
      .join('');
  }

  function renderRecentProjects(items: RecentProject[]) {
    if (items.length === 0) {
      recentProjEl.innerHTML = `<div class="ov-empty">no open projects</div>`;
      return;
    }
    recentProjEl.innerHTML = items
      .map(
        (p) => `
        <a class="ov-row" href="/admin/projects?id=${encodeURIComponent(p.id)}">
          <span class="ov-row-main">
            <span class="ov-row-title">${escapeHtml(p.name)}</span>
            <span class="ov-row-sub">${escapeHtml(p.client?.name ?? 'Unknown client')}</span>
          </span>
          <span class="ov-row-meta">
            ${statusBadge(p.status)}
            <span class="ov-row-date">${escapeHtml(penceToGBP(p.value_pence, p.currency))}</span>
          </span>
        </a>`,
      )
      .join('');
  }

  async function load() {
    const token = await getToken();
    if (!token) {
      window.location.href = '/admin/login';
      return;
    }
    try {
      const res = await fetch('/api/admin/overview', { headers: { Authorization: `Bearer ${token}` } });
      if (res.status === 401) {
        window.location.href = '/admin/login';
        return;
      }
      const json = await res.json();
      if (!res.ok || json.error) throw new Error(json.error ?? 'Failed to load overview.');
      renderKpis(json.kpis);
      renderRecentEnquiries(json.recentEnquiries ?? []);
      renderRecentProjects(json.recentProjects ?? []);
    } catch (err) {
      kpiGrid.innerHTML = '';
      recentEnqEl.innerHTML = '';
      recentProjEl.innerHTML = '';
      errorEl.textContent = (err as Error).message;
      errorEl.style.display = 'block';
    }
  }

  load();
</script>

<style>
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .kpi-tile {
    display: block;
    padding: var(--space-5);
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      border-color var(--duration-quick),
      background var(--duration-quick);
  }

  .kpi-tile:hover {
    border-color: var(--color-green-500);
    background: var(--color-surface-02);
  }

  .kpi-tile:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 2px;
  }

  .kpi-value {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.1;
  }

  .kpi-label {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 11px;
    font-variant: small-caps;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .kpi-note {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-warning);
  }

  .ov-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .ov-panel {
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .ov-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
    background: var(--color-surface-02);
  }

  .ov-panel-title {
    font-family: var(--font-mono);
    font-size: 12px;
    font-variant: small-caps;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .ov-panel-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-green-400);
    text-decoration: none;
  }

  .ov-panel-link:hover {
    color: var(--color-green-300);
  }

  .ov-loading,
  .ov-empty {
    padding: var(--space-6) var(--space-4);
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-muted);
    text-align: center;
  }

  .ov-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
    transition: background var(--duration-quick);
  }

  .ov-row:last-child {
    border-bottom: none;
  }

  .ov-row:hover {
    background: var(--color-surface-02);
  }

  .ov-row:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: -2px;
  }

  .ov-row-main {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .ov-row-title {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ov-row-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ov-row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .ov-row-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
  }

  .ov-quicklinks {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .ov-quicklink {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition:
      border-color var(--duration-quick),
      color var(--duration-quick);
  }

  .ov-quicklink:hover {
    border-color: var(--color-green-500);
    color: var(--color-green-400);
  }

  .ov-quicklink:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 2px;
  }

  @media (max-width: 860px) {
    .kpi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .ov-columns {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 420px) {
    .kpi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
