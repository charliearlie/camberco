---
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout title="Login">
  <main
    style="
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 48px);
      padding: var(--space-6);
    "
  >
    <div
      style="
        width: 100%;
        max-width: 380px;
        background: var(--color-surface-01);
        border: 1px solid var(--color-border-muted);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
      "
    >
      <!-- Heading -->
      <h1
        style="
          font-family: var(--font-mono);
          font-size: 16px;
          font-weight: 600;
          color: var(--color-green-500);
          margin: 0 0 var(--space-6);
          letter-spacing: 0.02em;
        "
      >
        $ camber login
      </h1>

      <!-- Error message -->
      <div
        id="login-error"
        style="
          display: none;
          padding: var(--space-2) var(--space-3);
          background: rgba(239,68,68,0.1);
          border: 1px solid rgba(239,68,68,0.3);
          border-radius: var(--radius-sm);
          font-family: var(--font-mono);
          font-size: 12px;
          color: var(--color-error);
          margin-bottom: var(--space-4);
        "
      >
      </div>

      <!-- Form -->
      <form id="login-form" style="display: flex; flex-direction: column; gap: var(--space-4);">
        <div class="metadata-field">
          <label for="login-email">email</label>
          <input
            id="login-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="you@example.com"
          />
        </div>

        <button
          id="login-btn"
          type="submit"
          style="
            height: 40px;
            background: var(--color-green-500);
            color: var(--color-text-inverse);
            font-family: var(--font-mono);
            font-size: 13px;
            font-weight: 600;
            font-variant: small-caps;
            letter-spacing: 0.06em;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: background var(--duration-quick);
          "
        >
          $ send magic link
        </button>
      </form>

      <!-- Success message (hidden by default) -->
      <div
        id="login-success"
        style="
          display: none;
          padding: var(--space-3) var(--space-4);
          background: rgba(34,197,94,0.1);
          border: 1px solid rgba(34,197,94,0.3);
          border-radius: var(--radius-sm);
          font-family: var(--font-mono);
          font-size: 13px;
          color: var(--color-green-500);
          text-align: center;
          line-height: 1.5;
        "
      >
        Check your email for a magic link to sign in.
      </div>
    </div>
  </main>
</AdminLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('login-error') as HTMLDivElement;
  const successEl = document.getElementById('login-success') as HTMLDivElement;
  const btn = document.getElementById('login-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.style.display = 'none';
    successEl.style.display = 'none';
    btn.disabled = true;
    btn.textContent = '$ sending…';

    const data = new FormData(form);
    const email = data.get('email') as string;

    try {
      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: {
          emailRedirectTo: `${window.location.origin}/admin/auth/callback`,
        },
      });

      if (error) throw error;

      form.style.display = 'none';
      successEl.style.display = 'block';
    } catch (err) {
      errorEl.textContent = (err as Error).message;
      errorEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = '$ send magic link';
    }
  });
</script>
