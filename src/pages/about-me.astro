---
import Layout from '../layouts/Layout.astro';
import { TYPEWRITER_CSS, initTypewriters } from '../scripts/typewriter.ts';
import { SCROLL_REVEAL_CSS, initScrollReveal } from '../scripts/scroll-reveal.ts';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://camberco.co.uk/about-me#person",
  "name": "Charlie W",
  "jobTitle": "AI Engineer & Founder Coach",
  "worksFor": { "@id": "https://camberco.co.uk/#organization" },
  "url": "https://camberco.co.uk/about-me",
  "knowsAbout": ["AI Automation", "N8n", "Workflow Automation", "Solo Founder Coaching", "OpenClaw"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "London",
    "addressCountry": "GB"
  }
});
---

<Layout
  title="Charlie W — AI Engineer & Founder Coach | Camber Co"
  description="Charlie W is a London-based AI engineer with 12 years of experience. Founder of Camber Co, coach to non-technical founders, and builder of AI systems that ship."
  canonicalUrl="https://camberco.co.uk/about-me"
  schema={schema}
>
  <main>

    <!-- ===== HERO ===== -->
    <section class="hero" id="hero">
      <div class="container">
        <div class="hero-inner">

          <div class="hero-copy">
            <div class="status-chip" data-reveal>
              <span class="status-dot" aria-hidden="true"></span>
              <span class="status-label">[ ACTIVE ]</span>
              <span class="status-path">camber/about</span>
            </div>

            <h1 class="hero-title" data-reveal>Charlie W</h1>

            <p class="hero-sub" data-reveal>
              Software engineer for 12 years. Building AI systems that ship.
            </p>
          </div>

          <div class="hero-terminal" data-reveal>
            <div class="tw-bar" aria-hidden="true">
              <span class="tw-dot tw-dot--red"></span>
              <span class="tw-dot tw-dot--yellow"></span>
              <span class="tw-dot tw-dot--green"></span>
              <span class="tw-label">camber — about.ts</span>
            </div>
            <div class="tw-body">
              <p class="tw-line"><span class="tw-prompt">$</span> <span class="tw-cmd">cat ./founder-origin.md</span></p>
              <div
                class="tw-output"
                data-typewriter
                data-lines='["2024: founded Camber Co to turn AI potential into working systems."]'
                data-speed="28"
                data-start-delay="600"
                aria-label="2024: founded Camber Co to turn AI potential into working systems."
              ></div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== JOURNEY ===== -->
    <section class="journey" id="journey">
      <div class="container">

        <div class="section-header" data-reveal>
          <p class="section-tag">journey</p>
          <h2 class="section-title">The signal through the noise.</h2>
        </div>

        <div class="timeline" data-reveal-stagger>

          <article class="timeline-item">
            <div class="tl-connector" aria-hidden="true">
              <span class="tl-dot"></span>
              <span class="tl-line"></span>
            </div>
            <div class="tl-content">
              <span class="tl-date">Early AI Wave</span>
              <h3 class="tl-heading">AI-Based Playwright Testing</h3>
              <p class="tl-body">
                Built AI-guided Playwright testing systems while AI was still early as a productivity
                layer, proving the technology could handle complex automation — and shipping it into
                production before most teams were paying attention.
              </p>
            </div>
          </article>

          <article class="timeline-item">
            <div class="tl-connector" aria-hidden="true">
              <span class="tl-dot"></span>
              <span class="tl-line"></span>
            </div>
            <div class="tl-content">
              <span class="tl-date">2024</span>
              <h3 class="tl-heading">Founded Camber Co</h3>
              <p class="tl-body">
                Turned years of AI engineering into a service for founders and small businesses.
                Camber Co exists to close the gap between AI potential and working product — fast,
                pragmatic, no slide decks.
              </p>
            </div>
          </article>

          <article class="timeline-item">
            <div class="tl-connector" aria-hidden="true">
              <span class="tl-dot"></span>
            </div>
            <div class="tl-content">
              <span class="tl-date">Current</span>
              <h3 class="tl-heading">From Zero to App Store</h3>
              <p class="tl-body">
                Mentored non-technical founders — people with no prior coding experience — and guided
                each one from first principles to shipping live AI products independently on the App Store.
              </p>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ===== PROJECTS ===== -->
    <section class="projects" id="projects">
      <div class="container">

        <div class="section-header" data-reveal>
          <p class="section-tag">projects</p>
          <h2 class="section-title">What we've shipped.</h2>
        </div>

        <div class="project-grid" data-reveal-stagger>

          <!-- Football IQ -->
          <article class="project-card">
            <div class="card-bar" aria-hidden="true">
              <span class="card-dot card-dot--red"></span>
              <span class="card-dot card-dot--yellow"></span>
              <span class="card-dot card-dot--green"></span>
              <span class="card-path">camber/football-iq</span>
            </div>
            <div class="card-body">
              <h3 class="card-title">Football IQ</h3>
              <p class="card-desc">
                Trivia app with daily challenges, built and shipped to the App Store.
              </p>
              <a
                href="https://www.football-iq.app/"
                class="card-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Football IQ at www.football-iq.app"
              >www.football-iq.app</a>
            </div>
          </article>

          <!-- Plus AI -->
          <article class="project-card">
            <div class="card-bar" aria-hidden="true">
              <span class="card-dot card-dot--red"></span>
              <span class="card-dot card-dot--yellow"></span>
              <span class="card-dot card-dot--green"></span>
              <span class="card-path">camber/plus-ai</span>
            </div>
            <div class="card-body">
              <h3 class="card-title">Plus AI Tools Suite</h3>
              <p class="card-desc">
                WhoScored Plus, Oddschecker Plus, Gazzetta AI Predictor — AI-assisted sports
                analysis tools built for high-volume audiences.
              </p>
              <div class="card-tags">
                <span class="card-tag">WhoScored Plus</span>
                <span class="card-tag">Oddschecker Plus</span>
                <span class="card-tag">Gazzetta AI</span>
              </div>
            </div>
          </article>

          <!-- QA Systems -->
          <article class="project-card">
            <div class="card-bar" aria-hidden="true">
              <span class="card-dot card-dot--red"></span>
              <span class="card-dot card-dot--yellow"></span>
              <span class="card-dot card-dot--green"></span>
              <span class="card-path">camber/qa-systems</span>
            </div>
            <div class="card-body">
              <h3 class="card-title">AI-Native QA Systems</h3>
              <p class="card-desc">
                Browser automation with AI. Playwright-based testing that understands what
                it's looking at — not just what it's clicking.
              </p>
              <div class="card-tags">
                <span class="card-tag">Playwright</span>
                <span class="card-tag">AI Testing</span>
                <span class="card-tag">Browser Automation</span>
              </div>
            </div>
          </article>

          <!-- Founder Acceleration -->
          <article class="project-card">
            <div class="card-bar" aria-hidden="true">
              <span class="card-dot card-dot--red"></span>
              <span class="card-dot card-dot--yellow"></span>
              <span class="card-dot card-dot--green"></span>
              <span class="card-path">camber/founder-acceleration</span>
            </div>
            <div class="card-body">
              <h3 class="card-title">Founder Acceleration</h3>
              <p class="card-desc">
                Non-technical founder mentorship. From zero knowledge to shipping products —
                with reusable build systems and practical AI workflows.
              </p>
              <div class="card-tags">
                <span class="card-tag">Mentorship</span>
                <span class="card-tag">Solo Founders</span>
                <span class="card-tag">AI Workflows</span>
              </div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ===== WRITING ===== -->
    <section class="writing" id="writing">
      <div class="container">
        <div class="section-header" data-reveal>
          <p class="section-tag">writing</p>
          <h2 class="section-title">What I'm thinking about.</h2>
        </div>
        <p class="writing-body" data-reveal>
          I write about AI strategy, automation, and the founder journey — lessons from building systems that ship.
          <a href="/blog" class="writing-link">Read the blog →</a>
        </p>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="cta" id="cta">
      <div class="container">
        <div class="cta-card" data-reveal>
          <h2 class="cta-title">Ready to build?</h2>
          <p class="cta-desc">
            Book a free 30-minute audit. We'll look at your operations, identify the highest-impact
            AI opportunities, and tell you honestly what's worth building. No pitch. No jargon.
            Just a clear path forward.
          </p>
          <a
            href="https://calendly.com/camber-co/30min"
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Book Free 30-Minute Audit
          </a>
          <p class="cta-flags" aria-label="No commitment, no jargon, just signal">
            <span class="flag">--no-commitment</span>
            <span class="flag">--no-jargon</span>
            <span class="flag">--just-signal</span>
          </p>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ============================================================
     Shared Layout
     ============================================================ */

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  /* ============================================================
     Hero
     ============================================================ */

  .hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding: clamp(80px, 12vw, 128px) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Status chip */
  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 12px;
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    width: fit-content;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-green-500);
    box-shadow: 0 0 6px var(--color-green-500);
    animation: status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-label {
    font-family: var(--font-mono);
    font-size: var(--type-label);
    color: var(--color-green-500);
    letter-spacing: 0.06em;
  }

  .status-path {
    font-family: var(--font-mono);
    font-size: var(--type-label);
    color: var(--color-text-muted);
  }

  /* H1 */
  .hero-title {
    font-family: var(--font-mono);
    font-size: var(--type-display);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0;
  }

  /* Sub */
  .hero-sub {
    font-family: var(--font-sans);
    font-size: var(--type-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 48ch;
  }

  /* Terminal panel */
  .hero-terminal {
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .tw-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 10px var(--space-4);
    background: var(--color-surface-02);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .tw-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .tw-dot--red    { background: #ff5f57; }
  .tw-dot--yellow { background: #ffbd2e; }
  .tw-dot--green  { background: #28c940; }

  .tw-label {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
    margin-left: var(--space-2);
  }

  .tw-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 100px;
  }

  .tw-line {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin: 0;
  }

  .tw-prompt {
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    color: var(--color-green-500);
    user-select: none;
    flex-shrink: 0;
  }

  .tw-cmd {
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    color: var(--color-text-secondary);
  }

  .tw-output {
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    color: var(--color-green-400);
    line-height: 1.6;
    min-height: 1.4em;
    padding-left: calc(var(--space-4) + 2px); /* align with cmd */
  }

  /* ============================================================
     Section shared
     ============================================================ */

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-tag {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green-500);
    margin: 0 0 var(--space-3);
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: var(--type-h1);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.1;
  }

  /* ============================================================
     Journey
     ============================================================ */

  .journey {
    padding: clamp(80px, 12vw, 128px) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-6);
    position: relative;
  }

  .tl-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
  }

  .tl-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-green-500);
    box-shadow: 0 0 8px var(--color-green-glow);
    flex-shrink: 0;
    z-index: 1;
    position: relative;
  }

  .tl-line {
    width: 1px;
    flex: 1;
    min-height: 40px;
    background: var(--color-border-subtle);
    margin-top: var(--space-2);
  }

  .tl-content {
    padding-bottom: clamp(32px, 5vw, 56px);
  }

  .tl-date {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-green-500);
    margin-bottom: var(--space-2);
  }

  .tl-heading {
    font-family: var(--font-mono);
    font-size: var(--type-h3);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
    letter-spacing: -0.01em;
  }

  .tl-body {
    font-family: var(--font-sans);
    font-size: var(--type-body);
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
    max-width: 60ch;
  }

  /* ============================================================
     Projects
     ============================================================ */

  .projects {
    padding: clamp(80px, 12vw, 128px) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  /* Terminal window card */
  .project-card {
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      border-color var(--duration-normal) var(--easing-smooth),
      box-shadow var(--duration-normal) var(--easing-smooth),
      transform var(--duration-normal) var(--easing-spring);
    will-change: transform;
  }

  .project-card:hover {
    border-color: var(--color-border-visible);
    box-shadow: 0 0 32px rgba(34, 197, 94, 0.06);
    transform: translateY(-2px);
  }

  .card-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 10px var(--space-4);
    background: var(--color-surface-02);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .card-dot--red    { background: #ff5f57; }
  .card-dot--yellow { background: #ffbd2e; }
  .card-dot--green  { background: #28c940; }

  .card-path {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
    margin-left: var(--space-2);
  }

  .card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .card-title {
    font-family: var(--font-mono);
    font-size: var(--type-h3);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-family: var(--font-sans);
    font-size: var(--type-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .card-link {
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    color: var(--color-green-500);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-quick) var(--easing-smooth);
    width: fit-content;
  }

  .card-link:hover {
    border-bottom-color: var(--color-green-500);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
    background: var(--color-surface-02);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 3px 8px;
    letter-spacing: 0.04em;
  }

  /* ============================================================
     Writing
     ============================================================ */

  .writing {
    padding: clamp(80px, 12vw, 128px) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .writing-body {
    font-family: var(--font-sans);
    font-size: var(--type-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 56ch;
    margin: 0;
  }

  .writing-link {
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    color: var(--color-green-500);
    text-decoration: none;
    display: inline-block;
    margin-top: var(--space-4);
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .writing-link:hover {
    color: var(--color-green-400);
  }

  /* ============================================================
     CTA
     ============================================================ */

  .cta {
    padding: clamp(80px, 12vw, 128px) 0;
  }

  .cta-card {
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: clamp(40px, 6vw, 72px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .cta-title {
    font-family: var(--font-mono);
    font-size: var(--type-h1);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.1;
  }

  .cta-desc {
    font-family: var(--font-sans);
    font-size: var(--type-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 56ch;
    margin: 0;
  }

  /* CTA Button */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: var(--radius-md);
    padding: 14px 28px;
    transition:
      background var(--duration-normal) var(--easing-smooth),
      box-shadow var(--duration-normal) var(--easing-smooth),
      transform var(--duration-normal) var(--easing-spring);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-green-500);
    color: var(--color-text-inverse);
  }

  .btn-primary:hover {
    background: var(--color-green-400);
    box-shadow: 0 0 24px var(--color-green-glow);
    transform: translateY(-2px);
  }

  .cta-flags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin: 0;
  }

  .flag {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  /* ============================================================
     Responsive
     ============================================================ */

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .hero-sub {
      max-width: 100%;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .cta-card {
      padding: var(--space-10) var(--space-6);
    }

    .cta-flags {
      flex-direction: column;
      align-items: center;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: clamp(40px, 12vw, 64px);
    }

    .tl-body {
      max-width: 100%;
    }
  }
</style>

<script>
  import { initTypewriters, TYPEWRITER_CSS } from '../scripts/typewriter.ts';
  import { initScrollReveal, SCROLL_REVEAL_CSS } from '../scripts/scroll-reveal.ts';

  // Inject animation CSS
  const style = document.createElement('style');
  style.textContent = TYPEWRITER_CSS + SCROLL_REVEAL_CSS;
  document.head.appendChild(style);

  // Boot animations
  initTypewriters();
  initScrollReveal();
</script>
