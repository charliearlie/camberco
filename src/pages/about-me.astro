<script>
  import { initScrollReveal, initCounters, SCROLL_REVEAL_CSS } from '../scripts/scroll-reveal.ts';
  import { initAboutTerminal } from '../scripts/about-terminal.ts';

  const style = document.createElement('style');
  style.textContent = SCROLL_REVEAL_CSS;
  document.head.appendChild(style);

  initScrollReveal();
  initCounters();
  initAboutTerminal();

  // Skill tooltip — single floating element, viewport-clamped.
  (function initSkillTooltip() {
    const tooltip = document.getElementById('skill-tooltip');
    if (!tooltip) return;

    const PAD = 8;
    const GAP = 10;

    function show(tag: HTMLElement) {
      const text = tag.dataset['context'];
      if (!text) return;
      tooltip!.textContent = text;
      tooltip!.classList.add('is-visible');
      tooltip!.setAttribute('aria-hidden', 'false');
      position(tag);
    }

    function hide() {
      tooltip!.classList.remove('is-visible');
      tooltip!.setAttribute('aria-hidden', 'true');
    }

    function position(tag: HTMLElement) {
      const tagRect = tag.getBoundingClientRect();
      const tipRect = tooltip!.getBoundingClientRect();
      const vw = window.innerWidth;
      const vh = window.innerHeight;

      // Horizontal: centred on tag, clamped to viewport with PAD margin.
      let left = tagRect.left + tagRect.width / 2 - tipRect.width / 2;
      left = Math.max(PAD, Math.min(left, vw - tipRect.width - PAD));

      // Vertical: above the tag if there's room, otherwise below.
      let top = tagRect.top - tipRect.height - GAP;
      if (top < PAD) {
        top = tagRect.bottom + GAP;
      }
      top = Math.min(top, vh - tipRect.height - PAD);

      tooltip!.style.left = `${left}px`;
      tooltip!.style.top = `${top}px`;
    }

    document.querySelectorAll<HTMLElement>('.skills-tag').forEach((tag) => {
      tag.addEventListener('mouseenter', () => show(tag));
      tag.addEventListener('focus', () => show(tag));
      tag.addEventListener('mouseleave', hide);
      tag.addEventListener('blur', hide);
    });

    window.addEventListener('scroll', hide, { passive: true });
    window.addEventListener('resize', hide, { passive: true });
  })();
</script>
