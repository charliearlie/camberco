  /* ================================
     SCROLL ANIMATIONS
     ================================ */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children in grids */
  .proof-grid .reveal:nth-child(2) { transition-delay: 0.1s; }
  .proof-grid .reveal:nth-child(3) { transition-delay: 0.2s; }
  .proof-grid .reveal:nth-child(4) { transition-delay: 0.3s; }

  .services-grid .reveal:nth-child(2) { transition-delay: 0.08s; }
  .services-grid .reveal:nth-child(3) { transition-delay: 0.16s; }
  .services-grid .reveal:nth-child(4) { transition-delay: 0.24s; }
  .services-grid .reveal:nth-child(5) { transition-delay: 0.32s; }
  .services-grid .reveal:nth-child(6) { transition-delay: 0.40s; }

  .metric-grid .metric:nth-child(2) { transition-delay: 0.1s; }
  .metric-grid .metric:nth-child(3) { transition-delay: 0.2s; }

  /* ================================
     RESPONSIVE
     ================================ */
  @media (max-width: 900px) {
    .nav-links { display: none; }
    .mobile-toggle { display: flex; }

    .proof-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .metric-grid { grid-template-columns: 1fr; gap: 28px; }

    .hero { padding: 130px 0 60px; }
    .hero-metric { margin-top: 56px; padding-top: 36px; }

    .proof, .services, .process, .results, .final-cta, .faq {
      padding: 72px 0;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .results .proof-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    body { font-size: 16px; }
    .services-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
    .footer-inner { flex-direction: column; gap: 16px; text-align: center; }
    .footer-right { justify-content: center; }
    .built-badge { text-align: left; }
    .step { gap: 20px; }
    .step-num { width: 44px; height: 44px; font-size: 20px; }
  }

  /* ================================
     REDUCED MOTION
     ================================ */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
    #hero-canvas { display: none; }
    html { scroll-behavior: auto; }
  }
</style>

<script type="module">
  // We use a module script to cleanly import Three.js while keeping your existing code running

  // --- 1. EXISTING UI LOGIC ---

  // Scroll reveal animation
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Nav scroll effect
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  });

  // Mobile menu
  const menuToggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('active');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('active');
    });
  });

  // Smooth anchor scrolling with offset for fixed nav
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        const offset = 80;
        const pos = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top: pos, behavior: 'smooth' });
      }
    });
  });


  // --- 2. WEBGL HERO ANIMATION (THREE.JS) ---

  import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const canvas = document.getElementById('hero-canvas');
    
    if (canvas) {
      const parent = canvas.parentElement;
      const scene = new THREE.Scene();
      
      const camera = new THREE.PerspectiveCamera(60, parent.clientWidth / parent.clientHeight, 0.1, 1000);
      const renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
      
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      
      // CRITICAL FIX: Pass 'false' as 3rd parameter to prevent Astro Layout thrashing / flicker
      renderer.setSize(parent.clientWidth, parent.clientHeight, false);

      const networkGroup = new THREE.Group();
      scene.add(networkGroup);

      // --- 1. GENERATE THE AI ROUTING MATRIX (NODES) ---
      const nodeCount = 120;
      const radius = 6;
      const nodes = [];
      const nodeSizes = new Float32Array(nodeCount);
      const isHubAttr = new Float32Array(nodeCount);
      
      // 6 Core Hubs (The AI Engines)
      for(let i=0; i<6; i++) {
         const theta = Math.random() * Math.PI * 2;
         const phi = Math.acos(2 * Math.random() - 1);
         const r = radius * 0.4; // Clustered near center
         nodes.push(new THREE.Vector3(
             r * Math.sin(phi) * Math.cos(theta),
             r * Math.sin(phi) * Math.sin(theta),
             r * Math.cos(phi)
         ));
         nodeSizes[i] = 14.0;
         isHubAttr[i] = 1.0;
      }

      // 114 Endpoints (Data Sources)
      for(let i=6; i<nodeCount; i++) {
         const theta = Math.random() * Math.PI * 2;
         const phi = Math.acos(2 * Math.random() - 1);
         const r = radius * (0.7 + Math.random() * 0.3); // Outer shell
         nodes.push(new THREE.Vector3(
             r * Math.sin(phi) * Math.cos(theta),
             r * Math.sin(phi) * Math.sin(theta),
             r * Math.cos(phi)
         ));
         nodeSizes[i] = 4.0;
         isHubAttr[i] = 0.0;
      }

      const pointsGeo = new THREE.BufferGeometry().setFromPoints(nodes);
      pointsGeo.setAttribute('size', new THREE.BufferAttribute(nodeSizes, 1));
      pointsGeo.setAttribute('isHub', new THREE.BufferAttribute(isHubAttr, 1));

      // Custom Shader for soft, branded nodes
      const pointsMat = new THREE.ShaderMaterial({
          vertexShader: `
              attribute float size;
              attribute float isHub;
              varying float vIsHub;
              void main() {
                  vIsHub = isHub;
                  vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
                  gl_PointSize = size * (10.0 / -mvPosition.z);
                  gl_Position = projectionMatrix * mvPosition;
              }
          `,
          fragmentShader: `
              varying float vIsHub;
              void main() {
                  float d = length(gl_PointCoord - vec2(0.5));
                  if (d > 0.5) discard;
                  float alpha = smoothstep(0.5, 0.4, d);
                  
                  // UPDATED: Softer Navy (Slate 600ish) for Hubs and lighter for endpoints
                  vec3 hubColor = vec3(0.28, 0.33, 0.41); // Softer slate/navy (#475569ish)
                  vec3 endColor = vec3(0.48, 0.54, 0.62); // Lighter slate
                  vec3 color = mix(endColor, hubColor, vIsHub);
                  
                  gl_FragColor = vec4(color, alpha * (0.5 + vIsHub * 0.5));
              }
          `,
          transparent: true,
          depthWrite: false
      });
      networkGroup.add(new THREE.Points(pointsGeo, pointsMat));

      // --- 2. GENERATE WORKFLOW CONNECTIONS (CURVED PATHS) ---
      const maxDist = 4.0;
      const curvePoints = [];
      const curveUvs = [];
      const curveSeeds = [];
      let connectionCount = 0;

      for (let i = 0; i < nodeCount; i++) {
        for (let j = i + 1; j < nodeCount; j++) {
          // Bias connections towards hubs to create a realistic network topology
          const isHubConnection = isHubAttr[i] === 1.0 || isHubAttr[j] === 1.0;
          const threshold = isHubConnection ? maxDist * 1.5 : maxDist;

          if (nodes[i].distanceTo(nodes[j]) < threshold && connectionCount < 300) {
            const start = nodes[i];
            const end = nodes[j];
            
            // Push control point outward from center to create beautiful organic arcs
            const mid = new THREE.Vector3().addVectors(start, end).multiplyScalar(0.5);
            const distFromCenter = mid.length();
            mid.normalize().multiplyScalar(distFromCenter + 1.0 + Math.random() * 0.5);

            const curve = new THREE.QuadraticBezierCurve3(start, mid, end);
            const segments = 15;
            const points = curve.getPoints(segments);
            
            const seed = Math.random() * 100.0;
            
            for (let k = 0; k < points.length - 1; k++) {
              curvePoints.push(points[k].x, points[k].y, points[k].z);
              curvePoints.push(points[k+1].x, points[k+1].y, points[k+1].z);
              
              // Map UVs across the entire length of the curved path
              curveUvs.push(k / segments, 0);
              curveUvs.push((k + 1) / segments, 0);
              
              curveSeeds.push(seed, seed);
            }
            connectionCount++;
          }
        }
      }

      const linesGeo = new THREE.BufferGeometry();
      linesGeo.setAttribute('position', new THREE.Float32BufferAttribute(curvePoints, 3));
      linesGeo.setAttribute('uv', new THREE.Float32BufferAttribute(curveUvs, 2));
      linesGeo.setAttribute('seed', new THREE.Float32BufferAttribute(curveSeeds, 1));

      // Shader to animate high-speed data packets along the workflow curves
      const linesMat = new THREE.ShaderMaterial({
          uniforms: {
              time: { value: 0 },
              baseColor: { value: new THREE.Color('#e2e8f0') }, // Much lighter background path
              pulseColor: { value: new THREE.Color('#475569') } // UPDATED: Softer slate pulse instead of harsh navy
          },
          vertexShader: `
              attribute float seed;
              varying vec2 vUv;
              varying float vSeed;
              void main() {
                  vUv = uv;
                  vSeed = seed;
                  gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
              }
          `,
          fragmentShader: `
              uniform float time;
              uniform vec3 baseColor;
              uniform vec3 pulseColor;
              
              varying vec2 vUv;
              varying float vSeed;
              
              void main() {
                  float speed = 0.15 + fract(vSeed * 1.234) * 0.25; 
                  float pulse = fract(time * speed + vSeed);
                  
                  // Calculate distance behind the pulse head
                  float dist = pulse - vUv.x;
                  if (dist < 0.0) dist += 1.0; // Wrap tail over edge
                  
                  // Only activate ~40% of the network pathways
                  float isActive = step(0.6, fract(vSeed * 7.89)); 
                  
                  float intensity = 0.0;
                  if (isActive > 0.5) {
                      float trail = 1.0 - smoothstep(0.0, 0.25, dist);
                      float head = 1.0 - smoothstep(0.0, 0.015, dist);
                      intensity = trail * 0.5 + head * 1.5; // Sharp, leading pulse
                  }
                  
                  vec3 finalColor = mix(baseColor, pulseColor, clamp(intensity, 0.0, 1.0));
                  float alpha = 0.2 + intensity; // Reveal faint path underneath
                  
                  gl_FragColor = vec4(finalColor, clamp(alpha, 0.0, 1.0));
              }
          `,
          transparent: true,
          depthWrite: false,
          blending: THREE.NormalBlending
      });

      const networkLines = new THREE.LineSegments(linesGeo, linesMat);
      networkGroup.add(networkLines);

      // --- 3. RAW DATA DUST (BACKGROUND CHAOS) ---
      const dustCount = 800;
      const dustPos = new Float32Array(dustCount * 3);
      for(let i=0; i<dustCount * 3; i++) {
         dustPos[i] = (Math.random() - 0.5) * 25; 
      }
      const dustGeo = new THREE.BufferGeometry();
      dustGeo.setAttribute('position', new THREE.BufferAttribute(dustPos, 3));
      const dustMat = new THREE.PointsMaterial({
         color: 0x94a3b8, // Lighter Slate 400
         size: 0.06,
         transparent: true,
         opacity: 0.25
      });
      const dust = new THREE.Points(dustGeo, dustMat);
      scene.add(dust);

      // --- 4. ANIMATION & INTERACTION ---
      camera.position.z = 10;
      camera.position.y = 2;

      let mouseX = 0;
      let mouseY = 0;
      let targetX = 0;
      let targetY = 0;
      const hasFineMouse = window.matchMedia('(pointer: fine)').matches;

      if (hasFineMouse) {
          document.addEventListener('mousemove', (event) => {
              mouseX = (event.clientX - window.innerWidth / 2) * 0.001;
              mouseY = (event.clientY - window.innerHeight / 2) * 0.001;
          });
      }

      let time = 0;
      let animId = 0;
      let isVisible = true;

      function animate() {
          if (!isVisible) return;
          animId = requestAnimationFrame(animate);
          time += 0.016; // Stable delta time

          linesMat.uniforms.time.value = time;

          // UPDATED: Smooth majestic rotation deeply influenced by mouse position
          networkGroup.rotation.y = time * 0.08 + mouseX * 2.0;
          networkGroup.rotation.x = mouseY * 1.5;
          networkGroup.rotation.z = time * 0.04 - mouseX * 0.5;
          dust.rotation.y = -time * 0.05 + mouseX * 0.5; // Counter-rotating raw data

          // Mouse Parallax Engine for Camera
          targetX = mouseX * 4.0; // Increased responsiveness multiplier
          targetY = mouseY * 4.0;
          camera.position.x += (targetX - camera.position.x) * 0.05;
          camera.position.y += (-targetY + 2.0 - camera.position.y) * 0.05; // Base Y offset
          camera.lookAt(scene.position);

          renderer.render(scene, camera);
      }

      animate();

      // --- 5. CLEANUP & PERFORMANCE ---
      let resizeTimer;
      const onResize = () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
              const w = parent.clientWidth;
              const h = parent.clientHeight;
              camera.aspect = w / h;
              camera.updateProjectionMatrix();
              // CRITICAL FIX: Ensure 'false' is passed during debounced resize too
              renderer.setSize(w, h, false);
          }, 200);
      };
      window.addEventListener('resize', onResize);

      // Halt calculations when user scrolls past the hero
      const heroSection = document.getElementById('hero');
      if (heroSection) {
          const heroObserver = new IntersectionObserver(([entry]) => {
              if (entry.isIntersecting && !isVisible) {
                  isVisible = true;
                  animate();
              } else if (!entry.isIntersecting) {
                  isVisible = false;
                  cancelAnimationFrame(animId);
              }
          }, { threshold: 0 });
          heroObserver.observe(heroSection);
      }

      const cleanup = () => {
          cancelAnimationFrame(animId);
          window.removeEventListener('resize', onResize);
          renderer.dispose();
          linesGeo.dispose();
          linesMat.dispose();
          pointsGeo.dispose();
          pointsMat.dispose();
          dustGeo.dispose();
          dustMat.dispose();
      };
      document.addEventListener('astro:before-swap', cleanup, { once: true });
      window.addEventListener('pagehide', cleanup);
    }
  }
</script>