// Camber Co LTD - Landing Page
---

<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Canonical URL -->
  <link rel="canonical" href="https://camberco.uk/" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Primary Meta Tags -->
  <title>AI Consultancy UK — Camber Co | We Build AI, Not Slide Decks</title>
  <meta name="description" content="Camber Co is a UK-based AI consultancy that builds and deploys AI automation, chatbots, and workflow tools for businesses. From AI readiness audits to full implementation. Based in England." />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="theme-color" content="#0f172a" />
  <meta name="author" content="Camber Co LTD" />
  <meta name="geo.region" content="GB" />
  <meta name="geo.placename" content="United Kingdom" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://camberco.uk/" />
  <meta property="og:title" content="AI Consultancy UK — Camber Co | We Build AI, Not Slide Decks" />
