  <meta property="og:image:alt" content="Camber Co — AI Consultancy UK. We build AI, not slide decks." />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:site_name" content="Camber Co" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="https://camberco.uk/" />
  <meta name="twitter:title" content="AI Consultancy UK — Camber Co | We Build AI, Not Slide Decks" />
  <meta name="twitter:description" content="UK AI consultancy that actually ships. We build automation, deploy AI tools, and train your team to use them. AI readiness audits from £750." />
  <meta name="twitter:image" content="https://camberco.uk/social.png" />
  <meta name="twitter:image:alt" content="Camber Co — AI Consultancy UK. We build AI, not slide decks." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- View Transitions -->
  <meta name="view-transition" content="same-origin" />

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://camberco.uk/#organization",
    "name": "Camber Co LTD",
    "alternateName": "Camber Co",
    "url": "https://camberco.uk",
    "logo": {
      "@type": "ImageObject",
      "url": "https://camberco.uk/logo.png",
      "width": 409,
      "height": 431
    },
    "image": "https://camberco.uk/social.png",
    "description": "Camber Co is a UK-based AI consultancy that builds and deploys AI automation, chatbots, workflow tools, and internal knowledge assistants for businesses. We don't just advise — we build working AI products and train your team to use them.",
    "email": "hello@camberco.uk",
    "sameAs": [
      "https://linkedin.com/company/camberco"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "London",
      "addressCountry": "GB"
    },
    "legalName": "Camber Co LTD",
    "areaServed": {
      "@type": "Country",
      "name": "United Kingdom"
    },
    "knowsAbout": [
      "Artificial Intelligence",
      "AI Automation",
      "AI Chatbots",
      "Workflow Automation",
      "Machine Learning",
      "Business Process Automation",
      "AI Consulting",
      "AI Strategy"
    ],
    "slogan": "We build AI. We don't just talk about it."
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://camberco.uk/#website",
    "url": "https://camberco.uk",
    "name": "Camber Co",
    "description": "UK AI consultancy that builds and deploys AI automation for businesses",
    "publisher": {
      "@id": "https://camberco.uk/#organization"
    },
    "inLanguage": "en-GB"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://camberco.uk/#webpage",
    "url": "https://camberco.uk",
    "name": "AI Consultancy UK — Camber Co | We Build AI, Not Slide Decks",
    "description": "Camber Co is a UK-based AI consultancy that builds and deploys AI automation, chatbots, and workflow tools for businesses.",
    "isPartOf": {
      "@id": "https://camberco.uk/#website"
    },
    "about": {
      "@id": "https://camberco.uk/#organization"
    },
    "inLanguage": "en-GB"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": "https://camberco.uk/#service",
    "name": "Camber Co — AI Consultancy Services",
    "url": "https://camberco.uk",
    "provider": {
      "@id": "https://camberco.uk/#organization"
    },
    "areaServed": {
      "@type": "Country",
      "name": "United Kingdom"
    },
    "serviceType": "AI Consultancy",
    "description": "End-to-end AI consultancy services for UK businesses including AI readiness audits, workflow automation, AI chatbots, internal knowledge assistants, fractional CTO services, and team training workshops.",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "AI Consultancy Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "AI Readiness Audit",
            "description": "Half-day assessment of your business. You get a prioritised report showing exactly where AI saves you time and money."
          },
          "price": "750",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Workflow Automation",
            "description": "We automate your most painful manual processes — invoicing, lead qualification, onboarding, and report generation."
          },
          "price": "2000",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "AI Chatbots and Assistants",
            "description": "Customer service bots for WhatsApp, web, or Messenger. Handle FAQs and bookings 24/7 with warm handoff to your team."
          },
          "price": "3000",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Internal Knowledge Assistant",
            "description": "AI trained on your docs, processes, and SOPs. New starter onboarding drops from weeks to days."
          },
          "price": "5000",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Fractional CTO",
            "description": "Embedded in your business 1-2 days a week. Strategic AI roadmap, vendor management, and team training."
          },
          "price": "3000",
          "priceCurrency": "GBP",
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": "3000",
            "priceCurrency": "GBP",
            "unitText": "month"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "AI Team Workshops",
            "description": "Hands-on AI training tailored to your industry and roles. Your team leaves knowing how to use AI effectively in their daily work."
          },
          "price": "1500",
          "priceCurrency": "GBP"
        }
      ]
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://camberco.uk/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does an AI consultancy do?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An AI consultancy helps businesses identify where artificial intelligence can save time, reduce costs, and improve operations. At Camber Co, we go beyond advising — we build and deploy working AI tools including workflow automation, AI chatbots, internal knowledge assistants, and custom AI-powered software. We then train your team to use everything we build, so you're never dependent on us."
        }
      },
      {
        "@type": "Question",
        "name": "How much does AI consultancy cost in the UK?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AI consultancy costs in the UK vary depending on the scope of work. At Camber Co, our AI readiness audit starts from £750 for a half-day assessment with a prioritised report. Workflow automation projects start from £2,000, AI chatbots from £3,000, internal knowledge assistants from £5,000, and our fractional CTO service starts from £3,000 per month. Every engagement begins with a free 30-minute consultation to understand your needs."
        }
      },
      {
        "@type": "Question",
        "name": "What is an AI readiness audit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An AI readiness audit is a focused assessment of your business operations, processes, and pain points to identify where AI can deliver the highest return on investment. Our audit takes half a day and produces a prioritised report showing exactly which processes to automate first, estimated time savings, and a clear implementation roadmap."
        }
      },
      {
        "@type": "Question",
        "name": "Can AI help small businesses in the UK?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. AI is particularly powerful for small businesses because it can automate the repetitive admin tasks that consume disproportionate amounts of time — invoicing, scheduling, customer enquiries, report generation, and onboarding. Camber Co works with UK businesses of all sizes and has helped sole traders and SMEs compress 120 hours of work into 20 hours using AI-augmented workflows."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between AI consultancy and traditional IT consultancy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Traditional IT consultancy focuses on infrastructure, software selection, and systems integration. AI consultancy specifically focuses on deploying artificial intelligence, machine learning, and automation to transform business processes. At Camber Co, we don't just advise on AI strategy — we build the actual AI tools, deploy them into your workflow, and train your team to use them."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to implement AI in a business?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Implementation timelines depend on complexity. A workflow automation can be built and deployed in 1-2 weeks. An AI chatbot for customer service typically takes 2-4 weeks. A full internal knowledge assistant may take 4-8 weeks. We start every engagement with an AI readiness audit so you get quick wins deployed first while larger projects are in development."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need technical knowledge to use AI tools built by Camber Co?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Every AI solution we build is designed for non-technical users. We handle all the development, deployment, and integration. Before we hand over, we run training sessions with your team so everyone knows how to use the tools effectively. Our goal is to make your team self-sufficient — you should never be dependent on us."
        }
      },
      {
        "@type": "Question",
        "name": "Why should I hire an AI consultant instead of using ChatGPT myself?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ChatGPT is a general-purpose tool. An AI consultant builds bespoke solutions tailored to your specific business processes. We integrate AI into your existing workflow, connect it to your data and tools, and automate entire processes end-to-end. The difference is between having a tool and having a system."
        }
      }
    ]
  }
  </script>
</head>

<body>
  <!-- ===== NAVIGATION ===== -->
  <nav class="nav" id="nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-text">Camber Co</span>
      </a>
      <div class="nav-links">
        <a href="#proof" class="nav-link">Results</a>
        <a href="#services" class="nav-link">Services</a>
        <a href="#process" class="nav-link">Process</a>
        <a href="#faq" class="nav-link">FAQ</a>
        <a href="https://calendly.com/camber-co/30min" class="nav-btn" target="_blank" rel="noopener noreferrer">Book Free Audit →</a>
      </div>
      <button class="mobile-toggle" aria-label="Menu" id="menuToggle">
        <span></span>
        <span></span>
      </button>
