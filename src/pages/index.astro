  .metric-grid .metric:nth-child(2) { transition-delay: 0.1s; }
  .metric-grid .metric:nth-child(3) { transition-delay: 0.2s; }

  /* ================================
     RESPONSIVE
     ================================ */
  @media (max-width: 900px) {
