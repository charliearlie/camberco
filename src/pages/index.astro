</style>

<script>
  import { initTypewriters } from '../scripts/typewriter.ts';
  import { initScrollReveal, initCounters } from '../scripts/scroll-reveal.ts';
  import { initTerminal } from '../scripts/terminal.ts';
  import { initChatDrawer } from '../scripts/chat-drawer.ts';

  // ── Init animations ──────────────────────────────────────────
  initTypewriters();
  initScrollReveal();
  initCounters();
  initTerminal();
  initChatDrawer();

  // ── Wire "explore" buttons on service cards to chat drawer ──
  document.querySelectorAll('[data-chat-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const service = (btn as HTMLElement).dataset.chatOpen;
      if (service && window.__openChatDrawer) {
        window.__openChatDrawer(service as any);
      }
    });
  });

  // ── Smooth anchor scrolling with 80px offset ─────────────────
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = (anchor as HTMLAnchorElement).getAttribute('href');
      if (!href) return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        const offset = 80;
        const pos = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top: pos, behavior: 'smooth' });
      }
    });
  });

  // ── Scroll indicator auto-hide ────────────────────────────────
  const scrollIndicator = document.getElementById('scrollIndicator');
  let scrollIndicatorHidden = false;

  if (scrollIndicator) {
    window.addEventListener('scroll', () => {
      if (!scrollIndicatorHidden && window.scrollY > 60) {
        scrollIndicatorHidden = true;
        scrollIndicator.classList.add('hidden');
      }
    }, { passive: true });
  }

</script>
