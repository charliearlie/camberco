    margin-bottom: 24px;
  }

  .footer-tagline {
    font-size: 14px;
    color: #94a3b8;
    margin-top: 4px;
  }

  .footer-about {
    font-size: 13px;
    color: #94a3b8;
    margin-top: 12px;
