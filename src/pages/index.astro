---
import Layout from '../layouts/Layout.astro';
import StarfieldHero from '../components/StarfieldHero.astro';
import ChatDrawer from '../components/ChatDrawer.astro';
import { getPublishedPosts } from '../lib/blog';
import BlogCard from '../components/blog/BlogCard.astro';

const recentPosts = (await getPublishedPosts()).slice(0, 3);

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://camberco.co.uk/#organization",
    "name": "Camber Co Ltd",
    "alternateName": "Camber Co",
    "url": "https://camberco.co.uk",
    "foundingDate": "2024",
    "founder": {
      "@type": "Person",
      "name": "Charlie W",
      "url": "https://camberco.co.uk/about-me"
    },
    "logo": {
      "@type": "ImageObject",
      "url": "https://camberco.co.uk/logo.png",
      "width": 409,
      "height": 431
    },
    "image": "https://camberco.co.uk/social.png",
    "description": "Camber Co is a London-based AI consultancy specialising in AI systems, n8n workflow automation, solo founder coaching, and personal AI assistants for UK founders and small businesses.",
    "email": "hello@camberco.co.uk",
    "sameAs": ["https://linkedin.com/company/camberco"],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "London",
      "addressCountry": "GB"
    },
    "legalName": "Camber Co Ltd",
    "areaServed": [
      { "@type": "City", "name": "London" },
      { "@type": "Country", "name": "United Kingdom" }
    ],
    "slogan": "Build faster. Think clearer. Ship smarter."
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://camberco.co.uk/#website",
    "url": "https://camberco.co.uk",
    "name": "Camber Co",
    "description": "AI systems, automation, and strategic coaching for UK founders who mean business.",
    "publisher": { "@id": "https://camberco.co.uk/#organization" },
    "inLanguage": "en-GB"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://camberco.co.uk/#webpage",
    "url": "https://camberco.co.uk",
    "name": "AI Services for UK Founders — Camber Co",
    "description": "AI systems, n8n workflow automation, solo founder training, and personal AI assistants for UK founders and small businesses. Based in London.",
    "isPartOf": { "@id": "https://camberco.co.uk/#website" },
    "about": { "@id": "https://camberco.co.uk/#organization" },
    "inLanguage": "en-GB"
  },
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "@id": "https://camberco.co.uk/#localbusiness",
    "name": "Camber Co",
    "url": "https://camberco.co.uk",
    "telephone": "",
    "email": "hello@camberco.co.uk",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "London",
      "addressCountry": "GB"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 51.5074,
      "longitude": -0.1278
    },
    "areaServed": [
      { "@type": "City", "name": "London" },
      { "@type": "Country", "name": "United Kingdom" }
    ],
    "priceRange": "££",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": "https://camberco.co.uk/#service",
    "name": "Camber Co — AI Services for Founders",
    "url": "https://camberco.co.uk",
    "provider": { "@id": "https://camberco.co.uk/#organization" },
    "areaServed": { "@type": "Country", "name": "United Kingdom" },
    "serviceType": "AI Consultancy",
    "description": "AI systems, n8n workflow automation, solo founder coaching, and personal AI assistants for UK founders and small businesses.",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "AI Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "AI Consultations",
            "description": "60-minute sessions to audit where AI will actually move the needle in your business. Clear decisions, clear next steps."
          },
          "price": "297",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Solo Founder Training",
            "description": "1:1 coaching sessions for non-technical founders who want to actually use AI in their business."
          },
          "price": "197",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "N8n Workflow Automation",
            "description": "Custom n8n pipelines that connect your tools, eliminate manual steps, and run without babysitting."
          },
          "price": "1200",
          "priceCurrency": "GBP"
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "OpenClaw Personal AI",
            "description": "Pre-configured AI bots for WhatsApp, Telegram, Slack, and Discord. Built on openclaw.ai — local, private, yours."
          },
          "price": "497",
          "priceCurrency": "GBP"
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://camberco.co.uk/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does an AI consultancy do?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An AI consultancy helps businesses identify where artificial intelligence can save time, reduce costs, and improve operations. At Camber Co, we go beyond advising — we build and deploy working AI tools including workflow automation, personal AI assistants, and AI coaching for founders. We work with solo founders and small businesses across the UK to implement AI that actually gets used."
        }
      },
      {
        "@type": "Question",
        "name": "How much does AI consultancy cost in the UK?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pricing at Camber Co depends on the scope of your project — every business is different. We offer AI consultations, workflow automation, founder training, and personal AI assistants. Every engagement starts with a free 30-minute audit call to understand your needs and recommend the right approach. No commitment required."
        }
      },
      {
        "@type": "Question",
        "name": "What is an AI readiness audit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An AI readiness audit is a focused assessment of your business operations and processes to identify where AI can deliver the highest return on investment. Our free 30-minute audit call and paid consultation sessions are designed to give you clarity on exactly which tasks to automate first and what tools to use — with no jargon and no commitment."
        }
      },
      {
        "@type": "Question",
        "name": "Can AI help small businesses in the UK?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. AI is particularly powerful for small businesses because it can automate the repetitive admin tasks that consume disproportionate amounts of time. Camber Co works with UK founders and SMEs to compress hours of manual work into automated workflows. Our approach is practical — we focus on the specific tasks eating your week and build solutions that run without constant supervision."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to implement AI in a business?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Implementation timelines depend on the scope. An n8n workflow automation can be built and deployed in 1-2 weeks. A personal AI assistant setup typically takes 3-5 days. Consultation and training sessions can start immediately. We prioritise quick wins that deliver value from day one."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need technical knowledge to use the AI tools you build?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Everything we build is designed for non-technical users. Our Solo Founder Training specifically targets founders without a technical background. We handle development, deployment, and integration, then ensure you understand how to run what we've built. You should never be dependent on us to operate your own systems."
        }
      },
      {
        "@type": "Question",
        "name": "Why hire an AI consultant instead of just using ChatGPT?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ChatGPT is a general-purpose tool. Camber Co builds bespoke solutions tailored to your specific business — connecting AI to your actual tools, data, and workflows. Instead of manually typing queries, we build systems that run automatically: n8n pipelines that handle tasks 24/7, or a personal AI assistant trained on your business context that lives inside WhatsApp or Slack."
        }
      },
      {
        "@type": "Question",
        "name": "Do you work with businesses outside London?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. While Camber Co is based in London, we work with founders and small businesses across the UK. Consultations, training, and strategy sessions are conducted remotely via video call. Automation and AI assistant projects are delivered fully remotely."
        }
      },
      {
        "@type": "Question",
        "name": "What is n8n workflow automation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "N8n is an open-source workflow automation platform that connects your business tools — email, CRM, spreadsheets, payment systems — and runs automated tasks between them 24/7. Camber Co builds and deploys custom n8n automations for UK businesses, typically saving 10-30 hours per month on repetitive processes."
        }
      },
      {
        "@type": "Question",
        "name": "What is a personal AI assistant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A personal AI assistant is an AI trained on your business context — your documents, processes, and knowledge — that runs on platforms you already use like WhatsApp, Telegram, or Slack. Unlike generic AI tools like ChatGPT, it knows your business specifically and can handle tasks, answer questions, and automate workflows tailored to your operations. Camber Co deploys these using OpenClaw, an open-source platform that keeps your data private and local."
        }
      },
      {
        "@type": "Question",
        "name": "What AI training do you offer for non-technical founders?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our Solo Founder Training is hands-on coaching designed for people who want to use AI in their business but don't have a technical background. We cover practical skills: how to evaluate AI tools, build simple automations, prompt effectively, and ship AI-powered features. Sessions are 1:1 and tailored to your specific business and goals."
        }
      }
    ]
  }
]);
---

<Layout
  title="AI Services for UK Founders — Camber Co"
  description="AI systems, automation, and strategic coaching for founders who mean business. Based in London, working with founders across the UK."
  canonicalUrl="https://camberco.co.uk/"
  schema={schema}
>
  <!-- ===== STARFIELD ===== -->
  <StarfieldHero />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="status-chip">
        <span class="status-dot"></span>
        CAMBER.CO // LONDON // EST. 2026
      </div>

      <h1 class="sr-only">AI Services for UK Founders and Small Businesses</h1>

      <div
        class="hero-display"
        data-typewriter
        data-lines='["Build faster.", "Think clearer.", "Ship smarter."]'
        data-speed="40"
      ></div>

      <p class="hero-sub">AI systems, automation, and strategic coaching for founders who mean business. Based in London, working with founders across the UK.</p>

      <div class="hero-ctas">
        <a href="https://calendly.com/camber-co/30min" class="btn-primary" target="_blank" rel="noopener noreferrer">&gt; Book Free Audit</a>
        <a href="#services" class="btn-ghost">&gt; See Services</a>
      </div>

      <div class="scroll-indicator" id="scrollIndicator">scroll to explore ↓</div>
    </div>
  </section>

  <!-- ===== SECTION DIVIDER 01 ===== -->
  <div class="section-divider">/* 01 — what we build */</div>

  <!-- ===== SERVICES ===== -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-tag">services</span>
        <h2>The stack we build on.</h2>
        <p>Not retainer engagements. Not vague strategy. Specific tools, specific outcomes.</p>
      </div>
      <div class="service-grid" data-reveal-stagger>

        <!-- Card 1: AI Consultations -->
        <div class="terminal-card">
          <div class="terminal-titlebar">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green-tc"></span>
            <span class="terminal-title">camber/consultations</span>
            <span class="terminal-status"><span class="status-dot"></span> ACTIVE</span>
          </div>
          <div class="terminal-body">
            <span class="terminal-comment">// strategic guidance</span>
            <h3>A roadmap for AI in your business.</h3>
            <p>60-minute sessions to audit where AI will actually move the needle. No fluff. Clear decisions, clear next steps.</p>
            <div class="terminal-footer">
              <button class="terminal-link" data-chat-open="consultations">→ explore</button>
            </div>
          </div>
        </div>

        <!-- Card 2: N8n Workflow Automation -->
        <div class="terminal-card">
          <div class="terminal-titlebar">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green-tc"></span>
            <span class="terminal-title">camber/automation</span>
            <span class="terminal-status"><span class="status-dot"></span> ACTIVE</span>
          </div>
          <div class="terminal-body">
            <span class="terminal-comment">// workflow engineering</span>
            <h3>Automate the work that's eating your week.</h3>
            <p>Custom n8n pipelines that connect your tools, eliminate manual steps, and run without babysitting.</p>
            <div class="terminal-footer">
              <button class="terminal-link" data-chat-open="automation">→ explore</button>
            </div>
          </div>
        </div>

        <!-- Card 3: Solo Founder Training -->
        <div class="terminal-card">
          <div class="terminal-titlebar">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green-tc"></span>
            <span class="terminal-title">camber/training</span>
            <span class="terminal-status terminal-status--available"><span class="status-dot status-dot--muted"></span> AVAILABLE</span>
          </div>
          <div class="terminal-body">
            <span class="terminal-comment">// founder coaching</span>
            <h3>Hands-on AI skills, no CS degree required.</h3>
            <p>Coaching sessions for non-technical founders who want to actually use AI, not just read about it.</p>
            <div class="terminal-footer">
              <button class="terminal-link" data-chat-open="training">→ explore</button>
            </div>
          </div>
        </div>

        <!-- Card 4: OpenClaw Personal AI -->
        <div class="terminal-card">
          <div class="terminal-titlebar">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green-tc"></span>
            <span class="terminal-title">camber/openclaw</span>
            <span class="terminal-status terminal-status--available"><span class="status-dot status-dot--muted"></span> AVAILABLE</span>
          </div>
          <div class="terminal-body">
            <span class="terminal-comment">// personal AI</span>
            <h3>Your business. Running on a private AI assistant.</h3>
            <p>Pre-configured AI bots for WhatsApp, Telegram, Slack, and Discord. Built on openclaw.ai — local, private, yours.</p>
            <div class="terminal-footer">
              <button class="terminal-link" data-chat-open="personal-ai">→ explore</button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHO WE WORK WITH ===== -->
  <section class="audience">
    <div class="container">
      <div class="audience-grid" data-reveal-stagger>
        <div class="audience-card">
          <h3>Solo founders &amp; indie hackers</h3>
          <p>AI is your force multiplier as a one-person business. We build the automation stack that lets you operate at a scale previously only possible with a team.</p>
        </div>
        <div class="audience-card">
          <h3>UK small business owners</h3>
          <p>Manual processes, admin overload, and tool sprawl are eating your time. We identify exactly which tasks AI can eliminate and build the systems to do it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION DIVIDER 02 ===== -->
  <div class="section-divider">/* 02 — the signal */</div>

  <!-- ===== ABOUT / PROOF ===== -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-left" data-reveal>
          <span class="section-tag">about</span>
          <h2>Built by someone who's done it.</h2>
          <p class="about-p">I'm Charlie. I've been building software for 12 years and using AI tools in production since before they were mainstream. Camber Co exists because I got tired of watching founders waste months on AI experiments that never shipped anything real.</p>
          <p class="about-p">I work with a small number of founders at a time — directly, hands-on. No account managers, no juniors. You get me, and you get results you can point at.</p>
          <a href="/blog" class="about-link">Read what I'm building and why →</a>
          <div class="stat-row">
            <div class="stat-block">
              <span class="stat-number" data-count-to="40" data-count-suffix="+">0+</span>
              <span class="stat-label">automations shipped</span>
            </div>
            <div class="stat-block">
              <span class="stat-number" data-count-to="12">0</span>
              <span class="stat-label">years building software</span>
            </div>
            <div class="stat-block">
              <span class="stat-number" data-count-to="2023">0</span>
              <span class="stat-label">building with AI</span>
            </div>
          </div>
        </div>
        <div class="about-right" data-reveal>
          <div class="terminal-readout" id="interactiveTerminal">
            <div class="terminal-titlebar">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green-tc"></span>
              <span class="terminal-title">camber/terminal</span>
            </div>
            <div class="terminal-body terminal-body--interactive" role="log" aria-label="Interactive terminal. Type help for available commands." aria-live="polite">
              <div class="terminal-output" id="terminalOutput"></div>
              <div class="terminal-input-line">
                <span class="terminal-prompt" aria-hidden="true">$</span>
                <div class="terminal-input-wrap">
                  <span class="terminal-ghost" id="terminalGhost" aria-hidden="true"></span>
                  <input
                    type="text"
                    id="terminalInput"
                    class="terminal-input"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                    placeholder="type a command..."
                    aria-label="Terminal command input"
                  />
                </div>
                <span class="terminal-tab-hint" aria-hidden="true">tab</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION DIVIDER 03 ===== -->
  <div class="section-divider">/* 03 — latest writing */</div>

  <!-- ===== LATEST WRITING ===== -->
  {recentPosts.length > 0 && (
    <section class="writing-section" id="writing">
      <div class="container">
        <div class="section-header" data-reveal>
          <span class="section-tag">writing</span>
          <h2>What we're thinking about.</h2>
        </div>
        <div class="writing-grid" data-reveal-stagger>
          {recentPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
        <div class="writing-cta" data-reveal>
          <a href="/blog" class="btn-ghost">&gt; See all posts</a>
        </div>
      </div>
    </section>
  )}

  <!-- ===== FAQ ===== -->
  <section class="faq" id="faq">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-tag">common questions</span>
        <h2>Frequently asked questions.</h2>
      </div>
      <div class="faq-list" data-reveal>

        <details class="faq-item" open>
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">What does an AI consultancy actually do?</span>
          </summary>
          <div class="faq-answer">
            <p>An AI consultancy helps businesses identify where artificial intelligence can save time, reduce costs, and improve operations. At Camber Co, we go beyond advising — we build and deploy working AI tools including n8n workflow automation, personal AI assistants for WhatsApp and Slack, and run hands-on coaching for non-technical founders. We work with a small number of clients at a time to ensure every engagement delivers something real.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">How much does AI consultancy cost in the UK?</span>
          </summary>
          <div class="faq-answer">
            <p>Pricing depends on what you need — every business is different. At Camber Co, every engagement starts with a free 30-minute audit call where we understand your situation and recommend the right approach. Click "explore" on any service to chat with our AI and get a personalised recommendation, or book a call directly. No commitment required.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">What is an AI readiness audit?</span>
          </summary>
          <div class="faq-answer">
            <p>An AI readiness audit is a focused assessment of your business operations and processes to identify where AI can deliver the highest return on investment. Our free 30-minute audit call and paid AI consultation sessions are designed to give you clarity on exactly which tasks to automate first and what tools to use — with no jargon and no commitment. You'll walk away with a clear, prioritised action list.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">Can AI help small businesses in the UK?</span>
          </summary>
          <div class="faq-answer">
            <p>Absolutely. AI is particularly powerful for small businesses because it can automate the repetitive admin tasks that consume disproportionate amounts of time. Camber Co works with UK founders and SMEs to compress hours of manual work into automated workflows. Our approach is practical — we focus on the specific tasks eating your week and build solutions that run without constant supervision.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">How long does it take to implement AI in a business?</span>
          </summary>
          <div class="faq-answer">
            <p>Implementation timelines depend on scope. An n8n workflow automation can be built and deployed in 1-2 weeks. A personal AI assistant setup typically takes 3-5 days. Consultation and training sessions can start immediately. We prioritise quick wins that deliver value from day one, so you see results before larger projects complete.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">Do I need technical knowledge to use the AI tools you build?</span>
          </summary>
          <div class="faq-answer">
            <p>No. Everything we build is designed for non-technical users. Our Solo Founder Training specifically targets founders without a technical background. We handle development, deployment, and integration, then ensure you understand how to run what we've built. You should never be dependent on us to operate your own systems — that's the whole point.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">Why hire an AI consultant instead of just using ChatGPT?</span>
          </summary>
          <div class="faq-answer">
            <p>ChatGPT is a general-purpose tool. Camber Co builds bespoke solutions tailored to your specific business — connecting AI to your actual tools, data, and workflows. Instead of manually typing queries, we build systems that run automatically: n8n pipelines that handle tasks 24/7, or a personal AI assistant trained on your business context that lives inside WhatsApp or Slack. The difference is between having a tool and having a system.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">Do you work with businesses outside London?</span>
          </summary>
          <div class="faq-answer">
            <p>Yes. While Camber Co is based in London, we work with founders and small businesses across the UK. Consultations, training, and strategy sessions are conducted remotely via video call. Automation and AI assistant projects are delivered fully remotely — geography is not a barrier.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-arrow">&gt;</span>
            <span class="faq-q-text">What is n8n workflow automation?</span>
          </summary>
          <div class="faq-answer">
            <p>N8n is an open-source workflow automation platform that connects your business tools — email, CRM, spreadsheets, payment systems — and runs automated tasks between them 24/7. Camber Co builds and deploys custom n8n automations for UK businesses, typically saving 10-30 hours per month on repetitive processes.</p>
          </div>
        </details>

        <details class="faq-item">
