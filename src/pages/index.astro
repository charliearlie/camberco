---
// Camber Co LTD - Landing Page
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>Camber Co — We Build AI. We Don't Just Talk About It.</title>
  <meta name="description" content="Camber Co helps businesses automate manual processes, ship AI-powered tools, and save thousands of hours. No slide decks. Working products." />
  <meta name="theme-color" content="#0f172a" />

  <!-- Open Graph -->
  <meta property="og:title" content="Camber Co — We Build AI. We Don't Just Talk About It." />
  <meta property="og:description" content="AI consultancy that actually ships. We build automation, deploy AI tools, and train your team to use them." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://camberco.uk" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- View Transitions -->
  <meta name="view-transition" content="same-origin" />
</head>

<body>
  <!-- ===== NAVIGATION ===== -->
  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-text">Camber Co</span>
      </a>
      <div class="nav-links">
        <a href="#proof" class="nav-link">Results</a>
        <a href="#services" class="nav-link">Services</a>
        <a href="#process" class="nav-link">Process</a>
        <a href="https://calendly.com/camber-co/30min" class="nav-btn" target="_blank" rel="noopener noreferrer">Book Free Audit →</a>
      </div>
      <button class="mobile-toggle" aria-label="Menu" id="menuToggle">
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="#proof" class="mobile-menu-link">Results</a>
    <a href="#services" class="mobile-menu-link">Services</a>
    <a href="#process" class="mobile-menu-link">Process</a>
    <a href="https://calendly.com/camber-co/30min" class="mobile-menu-link cta" target="_blank" rel="noopener noreferrer">Book Free Audit →</a>
  </div>

  <main>
    <!-- ===== HERO ===== -->
    <section class="hero" id="hero">
      <canvas id="hero-canvas" aria-hidden="true" role="presentation"></canvas>
      <div class="container">
        <div class="hero-content">
          <div class="hero-tag reveal">AI consultancy that ships</div>
          <h1 class="hero-title reveal">
            We don't advise on AI.<br />
            <em>We build it.</em>
          </h1>
          <p class="hero-subtitle reveal">
            Camber Co helps businesses automate manual processes, ship AI-powered
            tools, and save thousands of hours. No slide decks. Just working products
            your team can use from day one.
          </p>
          <div class="hero-actions reveal">
            <a href="https://calendly.com/camber-co/30min" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Book Your Free AI Audit</a>
            <a href="#proof" class="btn btn-ghost">See What We've Built ↓</a>
          </div>
        </div>
        <div class="hero-metric reveal">
          <div class="metric-grid">
            <div class="metric">
              <span class="metric-value">120→20</span>
              <span class="metric-label">Hours of work compressed using AI</span>
            </div>
            <div class="metric">
              <span class="metric-value">24/7</span>
              <span class="metric-label">AI automation running for clients</span>
            </div>
            <div class="metric">
              <span class="metric-value">0</span>
              <span class="metric-label">Slide decks produced. Ever.</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROOF POINTS ===== -->
    <section class="proof" id="proof">
      <div class="container">
        <div class="section-header reveal">
          <p class="section-tag">Proof, not promises</p>
          <h2 class="section-title">We eat our own cooking</h2>
          <p class="section-desc">Every tool we recommend, we use ourselves. Here's what powers Camber day-to-day.</p>
        </div>
        <div class="proof-grid">
          <div class="proof-card reveal">
            <div class="proof-number">01</div>
            <h3 class="proof-title">AI-Augmented Development</h3>
            <p class="proof-body">
              Our primary development environment. Advanced AI assistants connected to
              specialised context servers for design, databases, external APIs and more — turning
              multi-hour tasks into minutes.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Development</span>
              <span class="proof-tag">AI-Augmented</span>
            </div>
          </div>
          <div class="proof-card reveal">
            <div class="proof-number">02</div>
            <h3 class="proof-title">Autonomous Cloud Agent</h3>
            <p class="proof-body">
              An autonomous AI agent deployed in the cloud, managing this website
              and coordinating our schedule. Always on, always current, no manual
              upkeep required.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Autonomous Agent</span>
              <span class="proof-tag">Cloud</span>
            </div>
          </div>
          <div class="proof-card reveal">
            <div class="proof-number">03</div>
            <h3 class="proof-title">Intelligent Workflow Automation</h3>
            <p class="proof-body">
              When an audit is requested, an automated workflow picks it up instantly —
              triaging the enquiry, notifying our team, and kicking off
              onboarding before we've finished our coffee.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Workflow</span>
              <span class="proof-tag">Automation</span>
            </div>
          </div>
          <div class="proof-card reveal">
            <div class="proof-number">04</div>
            <h3 class="proof-title">Custom AI Tools</h3>
            <p class="proof-body">
              Purpose-built AI tools for marketing copy, financial reporting, and
              client analytics. Not off-the-shelf software — bespoke tools shaped
              around how we actually work.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Marketing</span>
              <span class="proof-tag">Accountancy</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SERVICES ===== -->
    <section class="services" id="services">
      <div class="container">
        <div class="section-header reveal">
          <p class="section-tag">What we do</p>
          <h2 class="section-title">From quick wins to full transformation</h2>
          <p class="section-desc">Every engagement starts with understanding your business. We build what you actually need, not what's trendy.</p>
        </div>
        <div class="services-grid">
          <div class="service-card reveal">
            <div class="service-icon">
              <img src="/svg/01-ai-readiness-audit.svg" alt="" width="56" height="56" onerror="this.style.display='none'" />
            </div>
            <h3>AI Readiness Audit</h3>
            <p>Half-day assessment of your business. You get a prioritised report showing exactly where AI saves you time and money. No fluff.</p>
            <span class="service-price">From £750</span>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <img src="/svg/02-workflow-automation.svg" alt="" width="56" height="56" onerror="this.style.display='none'" />
            </div>
            <h3>Workflow Automation</h3>
            <p>We automate your most painful manual processes. Invoicing, lead qualification, onboarding, report generation — built and deployed.</p>
            <span class="service-price">From £2,000</span>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <img src="/svg/03-ai-chatbots.svg" alt="" width="56" height="56" onerror="this.style.display='none'" />
            </div>
            <h3>AI Chatbots &amp; Assistants</h3>
            <p>Customer service bots for WhatsApp, web, or Messenger. Handle FAQs and bookings 24/7 with warm handoff to your team for complex queries.</p>
            <span class="service-price">From £3,000</span>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <img src="/svg/04-knowledge-assistant.svg" alt="" width="56" height="56" onerror="this.style.display='none'" />
            </div>
            <h3>Internal Knowledge Assistant</h3>
            <p>AI trained on your docs, processes, and SOPs. New starter onboarding drops from weeks to days. Your team's knowledge, available instantly.</p>
            <span class="service-price">From £5,000</span>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <img src="/svg/05-fractional-cto.svg" alt="" width="56" height="56" onerror="this.style.display='none'" />
            </div>
            <h3>Fractional CTO</h3>
            <p>Embedded in your business 1-2 days a week. Strategic AI roadmap, vendor management, team training. Your technology leader, without the full-time cost.</p>
            <span class="service-price">From £3,000/mo</span>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <img src="/svg/06-team-workshops.svg" alt="" width="56" height="56" onerror="this.style.display='none'" />
            </div>
            <h3>Team Workshops</h3>
            <p>Hands-on AI training tailored to your industry and roles. Your team leaves knowing how to use AI effectively in their daily work, not just what AI "could" do.</p>
            <span class="service-price">From £1,500</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROCESS ===== -->
    <section class="process" id="process">
      <div class="container">
        <div class="section-header reveal">
          <p class="section-tag">How it works</p>
          <h2 class="section-title">Three steps. No ambiguity.</h2>
        </div>
        <div class="process-steps">
          <div class="step reveal">
            <div class="step-num">1</div>
            <div class="step-content">
              <h3>We audit your business</h3>
              <p>A focused assessment of your operations, processes, and pain points. You get a clear report showing where AI delivers the highest ROI for your specific business.</p>
            </div>
          </div>
          <div class="step-line reveal"></div>
          <div class="step reveal">
            <div class="step-num">2</div>
            <div class="step-content">
              <h3>We build the solution</h3>
              <p>No 90-page strategy document. We build working automation, deploy AI tools, and integrate them into your existing workflow. You see results, not recommendations.</p>
            </div>
          </div>
          <div class="step-line reveal"></div>
          <div class="step reveal">
            <div class="step-num">3</div>
            <div class="step-content">
              <h3>We train your team</h3>
              <p>We hand over everything and make sure your people can run it. You're never dependent on us. That's the point.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== RESULTS ===== -->
    <section class="results" id="results">
      <div class="container">
        <div class="section-header reveal">
          <p class="section-tag">Track record</p>
          <h2 class="section-title">Real results, not case studies</h2>
          <p class="section-desc">Every project below was delivered using the same AI-augmented workflows we implement for clients.</p>
        </div>
        <div class="proof-grid">
          <div class="proof-card reveal">
            <div class="proof-number">01</div>
            <h3 class="proof-title">120 Hours → 20 Hours</h3>
            <p class="proof-body">
              We compressed 120 hours of work into 20 using the same AI-augmented
              workflows we implement for clients. Not a theoretical improvement.
              A measured, repeatable result across real projects.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Productivity</span>
              <span class="proof-tag">Workflow Design</span>
            </div>
          </div>
          <div class="proof-card reveal">
            <div class="proof-number">02</div>
            <h3 class="proof-title">WhatsApp Business Automation</h3>
            <p class="proof-body">
              Built an AI-powered WhatsApp bot handling scheduling, quoting, and
              customer enquiries. Fully automated, running 24/7, reducing response
              time from hours to seconds.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Chatbot</span>
              <span class="proof-tag">Customer Service</span>
            </div>
          </div>
          <div class="proof-card reveal">
            <div class="proof-number">03</div>
            <h3 class="proof-title">Football IQ — Solo AI-Built Product</h3>
            <p class="proof-body">
              A complete AI-powered product built from concept to launch by a single
              developer. No team. No agency. Proof that AI-augmented building
              doesn't just save time, it changes what's possible.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">Product Build</span>
              <span class="proof-tag">End-to-End</span>
            </div>
          </div>
          <div class="proof-card reveal">
            <div class="proof-number">04</div>
            <h3 class="proof-title">Solo App Developer — £20k Exit</h3>
            <p class="proof-body">
              A non-technical founder used our AI-augmented development workflow to
              build a complete app from scratch. No coding background. No development
              team. The app was built and sold for £20,000 in under 12 months.
            </p>
            <div class="proof-tag-row">
              <span class="proof-tag">App Development</span>
              <span class="proof-tag">Non-Technical Founder</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="final-cta" id="cta">
      <div class="container">
        <div class="cta-content reveal">
          <h2 class="cta-title">Find out what AI can<br /><em>actually</em> do for your business</h2>
          <p class="cta-desc">
            Book a free AI readiness audit. We'll assess your operations, identify
            the highest-impact opportunities, and show you exactly what's possible.
            No commitment. No sales pitch. Just clarity.
          </p>
          <a href="https://calendly.com/camber-co/30min" class="btn btn-primary btn-large" target="_blank" rel="noopener noreferrer">
            Book Your Free AI Audit
          </a>
          <p class="cta-note">30-minute call. We'll tell you honestly if AI is right for your business.</p>
        </div>
      </div>
    </section>
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-left">
        <span class="logo-text">Camber Co</span>
        <p class="footer-tagline">AI consultancy that builds.</p>
      </div>
      <div class="footer-right">
        <a href="https://linkedin.com/company/camberco" target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn</a>
        <a href="mailto:hello@camberco.uk" class="footer-link">hello@camberco.uk</a>
      </div>
    </div>
    <div class="container">
      <div class="built-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>This site was designed, built, and deployed in 30 minutes using AI-augmented workflows. That's the Camber Co difference.</span>
      </div>
      <p class="footer-legal">© 2025 Camber Co LTD. Registered in England and Wales.</p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  /* ================================
     RESET & BASE
     ================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Figtree', -apple-system, sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.7;
    color: #334155;
    background: #ffffff;
    overflow-x: hidden;
  }

  /* ================================
     TYPOGRAPHY
     ================================ */
  h1, h2, h3 {
    font-family: 'Instrument Serif', Georgia, serif;
    color: #0f172a;
    line-height: 1.15;
    font-weight: 400;
  }

  em {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* ================================
     LAYOUT
     ================================ */
  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ================================
     NAVIGATION
     ================================ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 24px;
    transition: all 0.3s ease;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    border-bottom-color: #e2e8f0;
  }

  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-text {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 24px;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .nav-link {
    font-size: 15px;
    font-weight: 500;
    color: #64748b;
    transition: color 0.2s;
    letter-spacing: -0.01em;
  }

  .nav-link:hover {
    color: #0f172a;
  }

  .nav-btn {
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    background: #0f172a;
    padding: 10px 22px;
    border-radius: 8px;
    transition: all 0.2s;
    letter-spacing: -0.01em;
  }

  .nav-btn:hover {
    background: #1e293b;
    transform: translateY(-1px);
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #0f172a;
    border-radius: 2px;
    transition: all 0.3s;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 24px;
    z-index: 99;
    flex-direction: column;
    gap: 20px;
  }

  .mobile-menu.active {
    display: flex;
  }

  .mobile-menu-link {
    font-size: 18px;
    font-weight: 500;
    color: #334155;
    padding: 8px 0;
  }

  .mobile-menu-link.cta {
    color: #0f172a;
    font-weight: 700;
  }

  /* ================================
     BUTTONS
     ================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Figtree', sans-serif;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 28px;
    border-radius: 10px;
    transition: all 0.25s ease;
    cursor: pointer;
    border: none;
    letter-spacing: -0.01em;
  }

  .btn-primary {
    background: #0f172a;
    color: #ffffff;
  }

  .btn-primary:hover {
    background: #1e293b;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.15);
  }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.9);
    color: #64748b;
    border: 1.5px solid #e2e8f0;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .btn-ghost:hover {
    color: #0f172a;
    border-color: #cbd5e1;
    background: #ffffff;
  }

  .btn-large {
    padding: 18px 36px;
    font-size: 18px;
    border-radius: 12px;
  }

  /* ================================
     HERO
     ================================ */
  .hero {
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(15, 23, 42, 0.03) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  #hero-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    display: block;
  }

  .hero > .container {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 720px;
  }

  .hero-tag {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: clamp(42px, 6vw, 72px);
    letter-spacing: -0.03em;
    margin-bottom: 28px;
    line-height: 1.05;
  }

  .hero-title em {
    color: #475569;
  }

  .hero-subtitle {
    font-size: 19px;
    line-height: 1.7;
    color: #64748b;
    max-width: 580px;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-metric {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid #e2e8f0;
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .metric-value {
    display: block;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 36px;
    color: #0f172a;
    letter-spacing: -0.03em;
    margin-bottom: 6px;
  }

  .metric-label {
    font-size: 14px;
    color: #94a3b8;
    line-height: 1.5;
  }

  /* ================================
     SECTION HEADERS
     ================================ */
  .section-tag {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 52px);
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .section-desc {
    font-size: 18px;
    color: #64748b;
    max-width: 560px;
    line-height: 1.7;
  }

  /* ================================
     PROOF SECTION
     ================================ */
  .proof {
    padding: 100px 0;
    background: #fafaf8;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-top: 56px;
  }

  .proof-card {
    padding: 40px 36px;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    transition: all 0.3s ease;
    position: relative;
  }

  .proof-card:hover {
    border-color: #cbd5e1;
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.06);
  }

  .proof-number {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 48px;
    color: #e2e8f0;
    letter-spacing: -0.04em;
