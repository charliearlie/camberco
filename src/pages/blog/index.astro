---
import { getPublishedPosts } from '../../lib/blog';
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import '../../styles/blog.css';

const posts = await getPublishedPosts();

const featuredPosts = posts.filter((p) => p.featured);
const regularPosts = posts.filter((p) => !p.featured);

const categories = [
  { value: 'all', label: 'All Posts' },
  { value: 'ai-strategy', label: 'AI Strategy' },
  { value: 'automation', label: 'Automation' },
  { value: 'case-study', label: 'Case Study' },
  { value: 'tools-and-workflows', label: 'Tools & Workflows' },
  { value: 'founder-journey', label: 'Founder Journey' },
  { value: 'industry-trends', label: 'Industry Trends' },
];

const blogSchema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "@id": "https://camberco.uk/blog/#blog",
    "name": "Camber Co Blog",
    "description": "AI strategy, n8n automation tutorials, and founder insights from Charlie W — helping UK founders build smarter with AI.",
    "url": "https://camberco.uk/blog/",
    "author": {
      "@type": "Person",
      "name": "Charlie W",
      "url": "https://camberco.uk/about-me"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Camber Co",
      "url": "https://camberco.uk"
    },
    "inLanguage": "en-GB"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://camberco.uk/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://camberco.uk/blog/"
      }
    ]
  }
]);
---

<Layout
  title="AI Strategy, Automation & Founder Insights — Camber Co Blog"
  description="Practical articles on AI strategy, n8n workflow automation, and the solo founder journey. Written by Charlie W for UK founders building real products with AI."
  canonicalUrl="https://camberco.uk/blog/"
  schema={blogSchema}
>
  <main class="blog-page">
    <!-- Header -->
    <header class="blog-header">
      <h1 class="blog-title">
        <span class="prompt">$</span>
        <span class="cmd"> camber </span>
        <span class="cmd">blog</span>
        <span class="flag"> --list</span>
      </h1>
      <p class="blog-subtitle">
        AI strategy, automation, and the founder journey — written for people building real things.
      </p>
      <p class="blog-intro">
        Camber Co works with UK founders to ship AI-powered products and automations. This blog is where we share what we're learning — from n8n workflow patterns and AI tool evaluations to the honest realities of building a business around artificial intelligence.
      </p>
    </header>

    <!-- Category filter -->
    <nav class="category-filter" aria-label="Filter posts by category">
      {categories.map((cat) => (
        <a
          href={cat.value === 'all' ? '/blog/' : `/blog/category/${cat.value}/`}
          class:list={['filter-chip', { active: cat.value === 'all' }]}
        >
          {cat.label}
        </a>
      ))}
    </nav>

    <!-- Featured post -->
    {featuredPosts.length > 0 && (
      <section class="featured-section" aria-label="Featured posts">
        <p class="featured-label">Featured</p>
        {featuredPosts.map((post) => (
          <BlogCard post={post} featured />
        ))}
      </section>
    )}

    <!-- Post grid -->
    {regularPosts.length > 0 && (
      <section aria-label="All posts">
        <p class="grid-label">All Posts</p>
        <div class="blog-grid">
          {regularPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </section>
    )}

    {posts.length === 0 && (
      <div class="blog-grid">
        <p class="no-posts">No posts yet. Check back soon.</p>
      </div>
    )}
  </main>
</Layout>
