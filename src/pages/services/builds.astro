---
import Layout from '../../layouts/Layout.astro';
import StarfieldHero from '../../components/StarfieldHero.astro';
import ChatDrawer from '../../components/ChatDrawer.astro';

const buildTypes = [
  {
    slug: 'landing-pages',
    title: 'Landing pages',
    desc: 'Single-purpose pages for launch, lead capture, waitlists, or paid campaigns.',
    tags: ['copy', 'conversion', 'speed'],
  },
  {
    slug: 'marketing-sites',
    title: 'Marketing sites',
    desc: 'Clear, fast company sites that explain what you do and make the next step obvious.',
    tags: ['Astro', 'CMS-ready', 'SEO'],
  },
  {
    slug: 'webapps',
    title: 'Webapps',
    desc: 'Focused dashboards, portals, calculators, and authenticated tools for real workflows.',
    tags: ['TypeScript', 'PostgreSQL', 'auth'],
  },
  {
    slug: 'mvps',
    title: 'MVPs',
    desc: 'The smallest useful version of the thing, shipped quickly enough to learn from.',
    tags: ['prototype', 'iterate', 'launch'],
  },
];

const processSteps = [
  {
    hash: 'b17d101',
    label: 'Discover',
    message: 'feat(scope): define the action the page needs to drive',
    body: 'We map the audience, offer, content, and one primary conversion path before design starts.',
  },
  {
    hash: 'c4a9e82',
    label: 'Design',
    message: 'feat(ui): turn the offer into a focused interface',
    body: 'Wireframes, copy structure, visual direction, and responsive states are shaped together.',
  },
  {
    hash: 'e08f443',
    label: 'Build',
    message: 'feat(ship): code the site with performance baked in',
    body: 'Astro, React, or Next.js when needed; vanilla where possible; analytics and forms wired properly.',
  },
  {
    hash: 'f9a2b60',
    label: 'Launch',
    message: 'chore(release): deploy, measure, and hand over cleanly',
    body: 'You get a fast deployment, clear handover notes, and a site that is easy to update.',
  },
];

const stack = ['Astro', 'Next.js', 'React', 'Tailwind', 'Cloudflare', 'PostgreSQL'];

const faqs = [
  {
    q: 'Can you work with an existing brand?',
    a: 'Yes. If you already have a brand, copy, or design system, the build will respect it. If not, we can create a lean visual direction as part of the project.',
  },
  {
    q: 'Do you only build Astro sites?',
    a: 'No. Astro is often the right fit for fast content and marketing sites, but Next.js, React, and PostgreSQL all make sense when the product needs richer app behavior.',
  },
  {
    q: 'Will I be able to edit the site?',
    a: 'Yes. The handover depends on the project, but the goal is always a site you can operate without needing a developer for small content changes.',
  },
  {
    q: 'Can you connect forms, payments, or dashboards?',
    a: 'Yes. Lightweight backend work, CRM handoff, Stripe, PostgreSQL, and admin views are all normal parts of build projects.',
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': 'https://camberco.co.uk/services/builds#service',
  name: 'Website and Web App Builds',
  serviceType: 'Web development',
  provider: { '@id': 'https://camberco.co.uk/#organization' },
  areaServed: {
    '@type': 'Country',
    name: 'United Kingdom',
  },
  url: 'https://camberco.co.uk/services/builds',
  description: 'Clean, fast websites, landing pages, web apps, and MVPs for UK founders and small businesses.',
});
---

<Layout
  title="Website & Web App Builds | Camber Co"
  description="Clean, fast websites, landing pages, web apps, and MVPs for founders and small businesses. Built by Camber Co in London."
  canonicalUrl="https://camberco.co.uk/services/builds"
  schema={schema}
>
  <StarfieldHero />

  <main class="service-page">
    <section class="hero">
      <div class="container">
        <div class="hero-copy" data-reveal>
          <div class="status-chip">
            <span class="status-dot" aria-hidden="true"></span>
            <span class="status-label">[ BUILD MODE ]</span>
            <span class="status-path">camber/services/builds</span>
          </div>
          <h1>Websites that make the offer obvious.</h1>
          <p>
            No toy generator. The work is sharper positioning, cleaner structure,
            faster pages, and conversion paths that feel intentional from the first screen.
          </p>
          <div class="hero-actions">
            <a href="/contact/" class="btn btn-primary">&gt; Start a build</a>
            <button type="button" class="btn btn-secondary" data-chat-open="builds">&gt; Chat about it</button>
          </div>
        </div>

        <div class="site-proof-demo" data-reveal>
          <div class="proof-browser">
            <div class="window-bar">
              <span class="window-dot window-dot--red"></span>
              <span class="window-dot window-dot--yellow"></span>
              <span class="window-dot window-dot--green"></span>
              <span class="browser-url">https://client-site.com/offer</span>
            </div>
            <div class="proof-browser-body">
              <div class="proof-site">
                <nav class="proof-site-nav" aria-label="Preview site navigation">
                  <span>Northstar Studio</span>
                  <span>availability open</span>
                </nav>

                <section class="proof-site-hero">
                  <span class="proof-kicker">Service page rebuild</span>
                  <h2>Turn visitor confusion into booked calls.</h2>
                  <p>
                    A focused page system for a premium consultancy: clearer offer,
                    sharper proof, faster load, and one obvious next step.
                  </p>
                  <div class="proof-site-actions" aria-label="Preview site actions">
                    <span>Book strategy call</span>
                    <span>View proof</span>
                  </div>
                </section>

                <div class="proof-metrics" aria-label="Preview quality signals">
                  <span><strong>95+</strong> performance target</span>
                  <span><strong>1</strong> primary conversion path</span>
                  <span><strong>0</strong> bloated plugins</span>
                </div>
              </div>
            </div>
          </div>

          <aside class="launch-board" aria-label="Website build diagnosis">
            <div class="launch-board-head">
              <span class="section-tag">$ camber audit --build</span>
              <strong>Launch board</strong>
            </div>
            <ol class="launch-checks">
              <li>
                <span>01</span>
                <div>
                  <strong>Positioning</strong>
                  <p>Lead with the commercial promise, not a vague capability list.</p>
                </div>
              </li>
              <li>
                <span>02</span>
                <div>
                  <strong>Conversion</strong>
                  <p>One primary action, repeated at natural decision points.</p>
                </div>
              </li>
              <li>
                <span>03</span>
                <div>
                  <strong>Performance</strong>
                  <p>Fast static delivery first, richer app behaviour only where it pays.</p>
                </div>
              </li>
              <li>
                <span>04</span>
                <div>
                  <strong>Handoff</strong>
                  <p>Clean code, documented edits, and a site you can actually operate.</p>
                </div>
              </li>
            </ol>
          </aside>
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="container">
        <div class="section-header" data-reveal>
          <p class="section-tag">$ ls builds/</p>
          <h2>What we build.</h2>
        </div>

        <div class="card-grid" data-reveal-stagger>
          {buildTypes.map((item) => (
            <article class="terminal-card">
              <div class="card-bar">
                <span class="window-dot window-dot--red"></span>
                <span class="window-dot window-dot--yellow"></span>
                <span class="window-dot window-dot--green"></span>
                <span class="card-path">~/{item.slug}</span>
              </div>
              <div class="card-body">
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
                <div class="card-tags">
                  {item.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block section-block--split">
      <div class="container">
        <div class="section-header" data-reveal>
          <p class="section-tag">$ git log --process</p>
          <h2>How the build ships.</h2>
        </div>

        <ol class="git-log" data-reveal-stagger>
          {processSteps.map((step, i) => (
            <li class="commit">
              <div class="commit-graph" aria-hidden="true">
                <span class="commit-dot"></span>
                {i < processSteps.length - 1 && <span class="commit-line"></span>}
              </div>
              <div class="commit-text">
                <span class="commit-line-1"><span class="commit-hash">commit&nbsp;{step.hash}</span></span>
                <span class="commit-line-2">Author: <span>camber@{step.label.toLowerCase()}</span></span>
                <span class="commit-message">{step.message}</span>
                <span class="commit-role">{step.label}</span>
                <p>{step.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section-block">
      <div class="container">
        <div class="section-header" data-reveal>
          <p class="section-tag">$ cat stack.txt</p>
          <h2>The usual stack.</h2>
        </div>
        <div class="pill-row" data-reveal>
          {stack.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="container">
        <div class="section-header" data-reveal>
          <p class="section-tag">$ man builds</p>
          <h2>Questions founders ask.</h2>
        </div>

        <div class="faq-list" data-reveal>
          {faqs.map((item, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>
                <span aria-hidden="true">&gt;</span>
                <span>{item.q}</span>
              </summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <div class="cta-card" data-reveal>
          <h2>Ready to ship the thing?</h2>
          <p>Bring the idea, the messy brief, or the half-built site. We will turn it into a clean build path.</p>
          <div class="cta-actions">
            <a href="/contact/" class="btn btn-primary">&gt; Get in touch</a>
            <button type="button" class="btn btn-secondary" data-chat-open="builds">&gt; Chat about it</button>
          </div>
          <p class="cta-flags">
            <span>--fast</span>
            <span>--focused</span>
            <span>--built-to-convert</span>
          </p>
        </div>
      </div>
    </section>
  </main>

  <ChatDrawer />
</Layout>

<style>
  .service-page {
    position: relative;
    z-index: 2;
    background: transparent;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .hero {
    padding: clamp(96px, 13vw, 148px) 0 clamp(72px, 9vw, 112px);
  }

  .hero-copy {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
    max-width: 760px;
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    padding: var(--space-2) var(--space-3);
    background: color-mix(in srgb, var(--color-surface-01) 76%, transparent);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-green-500);
    box-shadow: 0 0 10px var(--color-green-glow);
    animation: status-pulse 2.4s var(--easing-smooth) infinite;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }

  .status-label,
  .status-path {
    font-size: var(--type-label);
    letter-spacing: 0;
  }

  .status-label {
    color: var(--color-green-500);
  }

  .status-path {
    color: var(--color-text-muted);
  }

  h1 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--type-display);
    line-height: 1;
    letter-spacing: 0;
    color: var(--color-text-primary);
  }

  .hero-copy p,
  .section-header p {
    font-size: var(--type-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 64ch;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--type-label);
    font-weight: 700;
    letter-spacing: 0;
    transition:
      transform var(--duration-quick) var(--easing-spring),
      background var(--duration-quick) var(--easing-smooth),
      border-color var(--duration-quick) var(--easing-smooth),
      color var(--duration-quick) var(--easing-smooth),
      box-shadow var(--duration-quick) var(--easing-smooth);
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-green-500);
    color: var(--color-text-inverse);
  }

  .btn-primary:hover {
    background: var(--color-green-400);
    box-shadow: 0 0 24px var(--color-green-glow);
  }

  .btn-secondary {
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-muted);
    background: var(--color-surface-00);
  }

  .btn-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-visible);
    background: var(--color-surface-01);
  }

  .btn-small {
    min-height: 36px;
    padding: var(--space-2) var(--space-4);
    font-size: var(--type-caption);
  }

  .site-proof-demo {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
    gap: var(--space-4);
    align-items: stretch;
    background: color-mix(in srgb, var(--color-surface-00) 86%, transparent);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    box-shadow: 0 0 52px color-mix(in srgb, var(--color-green-500) 8%, transparent);
  }

  .terminal-window,
  .proof-browser,
  .launch-board,
  .terminal-card,
  .cta-card {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    background: var(--color-surface-00);
    overflow: hidden;
  }

  .window-bar,
  .card-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 38px;
    padding: 0 var(--space-3);
    background: var(--color-surface-02);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .window-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .window-dot--red {
    background: var(--color-error);
  }

  .window-dot--yellow {
    background: var(--color-warning);
  }

  .window-dot--green {
    background: var(--color-success);
  }

  .window-title,
  .card-path,
  .browser-url {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
  }

  .window-title,
  .card-path {
    margin-left: var(--space-2);
  }

  .browser-url {
    flex: 1;
    min-width: 0;
    margin-left: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    background: var(--color-surface-00);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .proof-browser-body {
    min-height: 600px;
    padding: var(--space-4);
    background:
      linear-gradient(0deg, color-mix(in srgb, var(--color-text-primary) 2%, transparent) 1px, transparent 1px),
      var(--color-surface-01);
    background-size: 100% var(--space-4);
  }

  .proof-site {
    min-height: 568px;
    display: grid;
    align-content: space-between;
    gap: var(--space-10);
    padding: clamp(var(--space-6), 5vw, var(--space-12));
    border: 1px solid color-mix(in srgb, var(--color-text-inverse) 14%, transparent);
    border-radius: var(--radius-md);
    background:
      radial-gradient(circle at 86% 12%, color-mix(in srgb, var(--color-pink-500) 22%, transparent), transparent 30%),
      linear-gradient(140deg, color-mix(in srgb, var(--color-text-primary) 94%, var(--color-green-500)), color-mix(in srgb, var(--color-text-primary) 90%, var(--color-pink-500)));
    color: var(--color-text-inverse);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-text-inverse) 6%, transparent);
  }

  .proof-site-nav,
  .proof-site-actions,
  .proof-metrics {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .proof-site-nav {
    justify-content: space-between;
    font-size: var(--type-caption);
    font-weight: 800;
  }

  .proof-site-nav span:last-child,
  .proof-kicker,
  .proof-site-actions span,
  .proof-metrics span {
    border: 1px solid color-mix(in srgb, var(--color-text-inverse) 14%, transparent);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-text-primary) 66%, transparent);
    box-shadow: 0 var(--space-2) var(--space-8) color-mix(in srgb, var(--color-text-inverse) 7%, transparent);
  }

  .proof-site-nav span:last-child {
    padding: var(--space-2) var(--space-3);
    color: color-mix(in srgb, var(--color-text-inverse) 70%, var(--color-green-500));
  }

  .proof-site-hero {
    display: grid;
    gap: var(--space-6);
    max-width: 680px;
  }

  .proof-kicker {
    width: fit-content;
    padding: var(--space-2) var(--space-3);
    color: color-mix(in srgb, var(--color-text-inverse) 70%, var(--color-pink-500));
    font-size: var(--type-caption);
    font-weight: 900;
  }

  .proof-site h2 {
    margin: 0;
    max-width: 11ch;
    font-family: var(--font-sans);
    font-size: clamp(var(--space-12), 7vw, var(--space-24));
    line-height: 0.95;
    letter-spacing: 0;
  }

  .proof-site p {
    max-width: 48ch;
    margin: 0;
    color: color-mix(in srgb, var(--color-text-inverse) 68%, var(--color-text-muted));
    font-size: var(--type-body-lg);
    line-height: 1.65;
  }

  .proof-site-actions span {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    font-size: var(--type-caption);
    font-weight: 900;
  }

  .proof-site-actions span:first-child {
    border-color: var(--color-green-500);
    background: var(--color-green-500);
  }

  .proof-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .proof-metrics span {
    min-height: 92px;
    display: grid;
    align-content: start;
    gap: var(--space-2);
    padding: var(--space-4);
    color: color-mix(in srgb, var(--color-text-inverse) 68%, var(--color-text-muted));
    font-size: var(--type-caption);
    line-height: 1.35;
  }

  .proof-metrics strong {
    display: block;
    color: var(--color-text-inverse);
    font-size: var(--type-h2);
    line-height: 1;
  }

  .launch-board {
    display: grid;
    align-content: start;
    gap: var(--space-6);
    padding: var(--space-6);
  }

  .launch-board-head {
    display: grid;
    gap: var(--space-2);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .launch-board-head .section-tag {
    margin: 0;
  }

  .launch-board-head strong {
    font-family: var(--font-mono);
    font-size: var(--type-h3);
    color: var(--color-text-primary);
  }

  .launch-checks {
    display: grid;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .launch-checks li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--color-green-500) 7%, transparent), transparent 56%),
      var(--color-surface-01);
  }

  .launch-checks li > span {
    font-family: var(--font-mono);
    color: var(--color-pink-500);
    font-weight: 800;
  }

  .launch-checks strong {
    display: block;
    margin-bottom: var(--space-1);
    color: var(--color-text-primary);
  }

  .launch-checks p {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: var(--type-body-sm);
  }

  .launch-checks li:hover {
    border-color: color-mix(in srgb, var(--color-green-500) 42%, var(--color-border-muted));
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-green-500) 7%, transparent);
  }

  .section-block {
    padding: clamp(72px, 10vw, 124px) 0;
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-base);
  }

  .section-header {
    margin-bottom: var(--space-10);
  }

  .section-tag {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-green-500);
  }

  h2 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--type-h1);
    line-height: 1.12;
    letter-spacing: 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .terminal-card {
    transition:
      transform var(--duration-normal) var(--easing-spring),
      border-color var(--duration-normal) var(--easing-smooth),
      box-shadow var(--duration-normal) var(--easing-smooth);
  }

  .terminal-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-green-500) 48%, var(--color-border-muted));
    box-shadow: 0 0 28px color-mix(in srgb, var(--color-green-500) 8%, transparent);
  }

  .card-body {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-6);
  }

  .card-body h3 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--type-h3);
    letter-spacing: 0;
  }

  .card-body p,
  .commit-text p,
