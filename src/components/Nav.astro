---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about-me' },
];
---

<nav
  id="site-nav"
  role="navigation"
  aria-label="Main navigation"
>
  <div class="nav-inner">
    <!-- Logotype -->
    <a href="/" class="logotype" aria-label="Camber Co — home">
      <span class="prompt" aria-hidden="true">$</span>
      <span class="wordmark">camber</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link">{link.label}</a>
        </li>
      ))}
    </ul>

    <!-- Theme toggle (desktop) -->
    <button
      class="theme-toggle theme-toggle--desktop"
      type="button"
      aria-label="Toggle colour theme"
      data-theme-toggle
    >
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <line x1="12" y1="2" x2="12" y2="4" />
        <line x1="12" y1="20" x2="12" y2="22" />
        <line x1="4.93" y1="4.93" x2="6.34" y2="6.34" />
        <line x1="17.66" y1="17.66" x2="19.07" y2="19.07" />
        <line x1="2" y1="12" x2="4" y2="12" />
        <line x1="20" y1="12" x2="22" y2="12" />
        <line x1="4.93" y1="19.07" x2="6.34" y2="17.66" />
        <line x1="17.66" y1="6.34" x2="19.07" y2="4.93" />
      </svg>
    </button>

    <!-- CTA -->
    <a
      href="/contact"
      class="cta-button"
    >
      &gt;&nbsp;Get in Touch
    </a>

    <!-- Mobile menu toggle -->
    <button
      class="mobile-toggle"
      id="mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-overlay"
    >
      <span class="toggle-prompt" aria-hidden="true">&gt;</span>
    </button>
  </div>
</nav>

<!-- Mobile full-screen overlay -->
<div
  class="mobile-overlay"
  id="mobile-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  hidden
>
  <button
    class="overlay-close"
    id="overlay-close"
    aria-label="Close menu"
  >
    <span aria-hidden="true">&#x2715;</span>
  </button>

  <ul class="overlay-links" role="list">
    {navLinks.map((link) => (
      <li>
        <a href={link.href} class="overlay-link">
          <span class="overlay-cmd" aria-hidden="true">$ camber </span>
          <span class="overlay-section">{link.label.toLowerCase()}</span>
        </a>
      </li>
    ))}
    <li>
      <a
        href="/contact"
        class="overlay-link overlay-cta"
      >
        <span class="overlay-cmd" aria-hidden="true">$ camber </span>
        <span class="overlay-section">contact</span>
      </a>
    </li>
    <li>
      <button
        type="button"
        class="overlay-link overlay-theme-toggle"
        aria-label="Toggle colour theme"
        data-theme-toggle
      >
        <span class="overlay-cmd" aria-hidden="true">$ camber </span>
        <span class="overlay-section">
          <span class="overlay-theme-label" data-theme-label-dark>theme --light</span>
          <span class="overlay-theme-label" data-theme-label-light>theme --dark</span>
        </span>
      </button>
    </li>
  </ul>
</div>

<script>
  // Scroll-based nav styling
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 20) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // run once on load in case page is already scrolled
  }

  // Mobile overlay toggle
  const toggle = document.getElementById('mobile-toggle');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('overlay-close');

  function openOverlay() {
    if (!overlay || !toggle) return;
    overlay.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeOverlay() {
    if (!overlay || !toggle) return;
    overlay.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    toggle.focus();
  }

  toggle?.addEventListener('click', openOverlay);
  closeBtn?.addEventListener('click', closeOverlay);

  // Close when a link inside the overlay is clicked
  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeOverlay);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay && !overlay.hidden) {
      closeOverlay();
    }
  });

  // Theme toggle
  function handleThemeToggle() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    try {
      localStorage.setItem('camber-theme', next);
    } catch (e) {}
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) {
      meta.setAttribute('content', next === 'light' ? '#ffffff' : '#000000');
    }
  }

  document
    .querySelectorAll<HTMLButtonElement>('[data-theme-toggle]')
    .forEach((btn) => btn.addEventListener('click', handleThemeToggle));
</script>

<style>
  /* ---- Nav shell ---- */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background var(--duration-normal) var(--easing-smooth),
      border-color var(--duration-normal) var(--easing-smooth),
      backdrop-filter var(--duration-normal) var(--easing-smooth);
  }

  nav.scrolled {
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border-subtle);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-8);
    gap: var(--space-8);
  }

  /* ---- Logotype ---- */
  .logotype {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .prompt {
    color: var(--color-green-500);
  }

  .wordmark {
    color: var(--color-text-primary);
  }

  /* ---- Desktop nav links ---- */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--type-label);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-text-primary);
    outline: none;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* ---- CTA button ---- */
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: var(--color-green-500);
    color: var(--color-on-accent);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      background var(--duration-quick) var(--easing-smooth),
      transform var(--duration-quick) var(--easing-spring);
  }

  .cta-button:hover {
    background: var(--color-green-400);
    transform: translateY(-1px);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 3px;
  }

  .cta-button:active {
    transform: translateY(0);
  }

  /* ---- Theme toggle (desktop) ---- */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-text-secondary);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition:
      color var(--duration-quick) var(--easing-smooth),
      background var(--duration-quick) var(--easing-smooth);
  }

  .theme-toggle:hover {
    color: var(--color-text-primary);
    background: var(--color-surface-01);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 2px;
  }

  .theme-toggle .icon-sun,
  .theme-toggle .icon-moon {
    display: none;
  }

  /* Default (dark theme): show the sun (action: switch TO light) */
  :root:not([data-theme='light']) .theme-toggle .icon-sun {
    display: block;
  }
  :root[data-theme='light'] .theme-toggle .icon-moon {
    display: block;
  }

  /* Mobile theme toggle inside overlay */
  .overlay-theme-toggle {
    background: none;
    border: none;
    text-align: left;
    width: 100%;
    cursor: pointer;
  }

  .overlay-theme-label {
    display: none;
  }
  :root:not([data-theme='light']) [data-theme-label-dark] {
    display: inline;
  }
  :root[data-theme='light'] [data-theme-label-light] {
    display: inline;
  }

  /* ---- Mobile toggle ---- */
  .mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin-left: auto;
    color: var(--color-green-500);
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    border-radius: var(--radius-sm);
    transition: background var(--duration-quick) var(--easing-smooth);
  }

  .mobile-toggle:hover {
    background: var(--color-green-glow);
  }

  .mobile-toggle:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 2px;
  }

  .toggle-prompt {
    line-height: 1;
  }

  /* ---- Mobile overlay ---- */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--color-base);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: var(--space-12) var(--space-8);
  }

  .mobile-overlay[hidden] {
    display: none;
  }

  .overlay-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-6);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: 20px;
    border-radius: var(--radius-sm);
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .overlay-close:hover {
    color: var(--color-text-primary);
  }

  .overlay-close:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 2px;
  }

  .overlay-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    width: 100%;
  }

  .overlay-link {
    display: flex;
    align-items: baseline;
    gap: 0;
    font-family: var(--font-mono);
    font-size: clamp(22px, 6vw, 36px);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-secondary);
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .overlay-link:hover,
  .overlay-link:focus-visible {
    color: var(--color-text-primary);
    outline: none;
  }

  .overlay-link:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .overlay-cmd {
    color: var(--color-text-muted);
    font-size: 0.5em;
    align-self: center;
    white-space: pre;
  }

  .overlay-section {
    color: var(--color-text-primary);
  }

  .overlay-cta .overlay-section {
    color: var(--color-green-500);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .cta-button {
      display: none;
    }

    .theme-toggle--desktop {
      display: none;
    }

    .mobile-toggle {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .mobile-overlay {
      display: none !important;
    }
  }
</style>
