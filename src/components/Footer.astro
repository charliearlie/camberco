---
const navLinks = [
  { label: '~/services', href: '/services' },
  { label: '~/blog', href: '/blog' },
  { label: '~/about', href: '/about-me' },
];
---

<footer>
  <div class="footer-inner">
    <!-- Main grid -->
    <div class="footer-grid">

      <!-- Column 1: Brand -->
      <div class="col col-brand">
        <a href="/" class="logotype" aria-label="Camber Co — home">
          <span class="prompt" aria-hidden="true">$</span>
          <span class="wordmark">camber</span>
        </a>
        <p class="tagline">AI services for founders who move fast.</p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="col col-nav">
        <p class="col-label">Navigation</p>
        <ul role="list" class="link-list">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Connect -->
      <div class="col col-connect">
        <p class="col-label">Connect</p>
        <ul role="list" class="link-list">
          <li>
            <a href="mailto:hello@camberco.co.uk" class="footer-link">
              hello@camberco.co.uk
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/company/camber-co"
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="/contact/"
              class="footer-link footer-link--cta"
            >
              Get in Touch
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Newsletter -->
    <div class="footer-newsletter">
      <p class="col-label">Newsletter</p>
      <p class="newsletter-desc">New posts delivered to your inbox.</p>
      <form class="footer-nl-form" data-newsletter-form>
        <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="footer-nl-row">
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            required
            autocomplete="email"
            class="footer-nl-input"
          />
          <button type="submit" class="footer-nl-btn">
            <span class="btn-text">&gt; Subscribe</span>
            <span class="btn-loading" style="display:none">...</span>
          </button>
        </div>
        <p class="footer-nl-msg" data-newsletter-msg></p>
      </form>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="version-string">
        $ camber --version 2.0.0 // London, UK // All systems operational
      </p>
      <p class="copyright">&copy; 2026 Camber Co Ltd</p>
    </div>

  </div>
</footer>

<style>
  footer {
    background: var(--color-base);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-8) var(--space-10);
  }

  /* ---- Main grid ---- */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ---- Brand column ---- */
  .logotype {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    width: fit-content;
  }

  .prompt {
    color: var(--color-green-500);
  }

  .wordmark {
    color: var(--color-text-primary);
  }

  .tagline {
    font-size: var(--type-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-top: var(--space-1);
  }

  /* ---- Column labels ---- */
  .col-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  /* ---- Link lists ---- */
  .link-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--type-body-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-green-500);
    outline: none;
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--color-green-500);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .footer-link--cta {
    color: var(--color-green-500);
    font-weight: 600;
  }

  .footer-link--cta:hover {
    color: var(--color-green-400);
  }

  /* ---- Newsletter ---- */
  .footer-newsletter {
    margin-bottom: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-subtle);
    max-width: 440px;
  }

  .newsletter-desc {
    font-family: var(--font-sans);
    font-size: var(--type-body-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.5;
  }

  .footer-nl-row {
    display: flex;
    gap: var(--space-3);
  }

  .footer-nl-input {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-primary);
    background: var(--color-surface-02);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-sm);
    padding: 8px 12px;
    outline: none;
    transition: border-color var(--duration-quick) var(--easing-smooth);
  }

  .footer-nl-input::placeholder {
    color: var(--color-text-muted);
  }

  .footer-nl-input:focus {
    border-color: var(--color-green-500);
  }

  .footer-nl-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--color-green-500);
    color: #000;
    padding: 8px 14px;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background var(--duration-quick) var(--easing-smooth),
      transform var(--duration-quick) var(--easing-spring);
  }

  .footer-nl-btn:hover:not(:disabled) {
    background: var(--color-green-400);
    transform: translateY(-1px);
  }

  .footer-nl-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .footer-nl-msg {
    font-family: var(--font-mono);
    font-size: 12px;
    margin: var(--space-2) 0 0 0;
    min-height: 18px;
  }

  .footer-nl-msg:global(.success) {
    color: var(--color-green-500);
  }

  .footer-nl-msg:global(.error) {
    color: var(--color-error);
  }

  /* ---- Bottom bar ---- */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
    padding-top: var(--space-6);
  }

  .version-string {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .copyright {
    font-family: var(--font-mono);
    font-size: var(--type-caption);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .footer-inner {
      padding: var(--space-12) var(--space-6) var(--space-8);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .version-string {
      word-break: break-all;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      padding: var(--space-10) var(--space-4) var(--space-6);
    }
  }
</style>

<script>
  document.querySelectorAll('[data-newsletter-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const msg = f.querySelector('[data-newsletter-msg]') as HTMLElement;
      const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
      const btnText = btn.querySelector('.btn-text') as HTMLElement;
      const btnLoading = btn.querySelector('.btn-loading') as HTMLElement;
      const input = f.querySelector('input[name="email"]') as HTMLInputElement;
      const honeypot = f.querySelector('input[name="website"]') as HTMLInputElement;

      btn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline';
      msg.textContent = '';
      msg.className = msg.className.replace(/\b(success|error)\b/g, '').trim();

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: input.value, website: honeypot.value }),
        });
        const data = await res.json();

        if (res.ok) {
          msg.textContent = 'Check your inbox to confirm.';
          msg.classList.add('success');
          input.value = '';
        } else {
          msg.textContent = data.error || 'Something went wrong.';
          msg.classList.add('error');
        }
      } catch {
        msg.textContent = 'Something went wrong.';
        msg.classList.add('error');
      }

      btn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    });
  });
</script>
