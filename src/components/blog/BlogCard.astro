---
import type { BlogPost } from '../../lib/blog';
import CategoryBadge from './CategoryBadge.astro';
import { getReadingTime } from '../../lib/reading-time';

interface Props {
  post: BlogPost;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, publishedAt, category, coverImage, coverImageAlt } = post;

const readingTime = getReadingTime(post.content);
const formattedDate = publishedAt.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
const postUrl = `/blog/${post.slug}/`;
---

<article class:list={['blog-card', { featured }]}>
  {coverImage && (
    <a href={postUrl} class="card-image-link" tabindex="-1" aria-hidden="true">
      <div class="card-image">
        <img src={coverImage} alt={coverImageAlt ?? title} loading="lazy" decoding="async" />
      </div>
    </a>
  )}
  <div class="card-body">
    <div class="card-meta">
      <CategoryBadge category={category} small />
      <time datetime={publishedAt.toISOString()} class="card-date">{formattedDate}</time>
    </div>
    <h2 class="card-title">
      <a href={postUrl} class="card-title-link">{title}</a>
    </h2>
    <p class="card-description">{description}</p>
    <footer class="card-footer">
      <span class="reading-time">{readingTime} min read</span>
      <a href={postUrl} class="read-more" aria-label={`Read ${title}`}>
        read_more<span class="arrow" aria-hidden="true"> →</span>
      </a>
    </footer>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      border-color var(--duration-normal) var(--easing-smooth),
      transform var(--duration-normal) var(--easing-spring);
  }

  .blog-card:hover {
    border-color: var(--color-green-500);
    transform: translateY(-2px);
  }

  /* Featured variant */
  .blog-card.featured {
    flex-direction: row;
  }

  .blog-card.featured .card-image {
    aspect-ratio: 16 / 9;
    min-height: 100%;
  }

  .blog-card.featured .card-image-link {
    flex: 0 0 45%;
  }

  .blog-card.featured .card-body {
    flex: 1;
    padding: var(--space-8);
  }

  .blog-card.featured .card-title {
    font-size: 24px;
  }

  /* Card image */
  .card-image-link {
    display: block;
    overflow: hidden;
    background: var(--color-surface-02);
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--easing-smooth);
    display: block;
  }

  .blog-card:hover .card-image img {
    transform: scale(1.03);
  }

  /* Card body */
  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-6);
    gap: var(--space-3);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .card-title {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .card-title-link {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .card-title-link:hover {
    color: var(--color-green-400);
  }

  .card-description {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-muted);
    flex: 1;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .read-more {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-green-500);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color var(--duration-quick) var(--easing-smooth);
  }

  .read-more:hover {
    color: var(--color-green-400);
  }

  .arrow {
    display: inline-block;
    transition: transform var(--duration-quick) var(--easing-spring);
  }

  .read-more:hover .arrow {
    transform: translateX(3px);
  }

  /* Responsive — collapse featured to column on mobile */
  @media (max-width: 768px) {
    .blog-card.featured {
      flex-direction: column;
    }

    .blog-card.featured .card-image-link {
      flex: none;
    }

    .blog-card.featured .card-body {
      padding: var(--space-6);
    }

    .blog-card.featured .card-title {
      font-size: 20px;
    }
  }
</style>
