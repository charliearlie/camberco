---
// NewsletterSignup.astro — email signup form for blog digest
---

<div class="newsletter-signup">
  <div class="newsletter-inner">
    <p class="newsletter-label">$ subscribe</p>
    <p class="newsletter-copy">Get new posts in your inbox. No spam, unsubscribe any time.</p>
    <form class="newsletter-form" data-blog-newsletter-form>
      <!-- Honeypot -->
      <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
      <div class="newsletter-row">
        <input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          autocomplete="email"
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">
          <span class="btn-text">&gt; Subscribe</span>
          <span class="btn-loading" style="display:none">...</span>
        </button>
      </div>
      <p class="newsletter-msg" data-newsletter-msg></p>
      <p class="newsletter-consent">
        You are signing up for occasional Camber Co emails. One-click
        unsubscribe, any time. <a href="/privacy">Privacy policy</a>.
      </p>
    </form>
  </div>
</div>

<script>
  document.querySelectorAll('[data-blog-newsletter-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const msg = f.querySelector('[data-newsletter-msg]') as HTMLElement;
      const btn = f.querySelector('.newsletter-btn') as HTMLButtonElement;
      const btnText = btn.querySelector('.btn-text') as HTMLElement;
      const btnLoading = btn.querySelector('.btn-loading') as HTMLElement;
      const input = f.querySelector('input[name="email"]') as HTMLInputElement;
      const honeypot = f.querySelector('input[name="website"]') as HTMLInputElement;

      btn.disabled = true;
      btnText.style.display = 'none';
      btnLoading.style.display = 'inline';
      msg.textContent = '';
      msg.className = 'newsletter-msg';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: input.value, website: honeypot.value }),
        });
        const data = await res.json();

        if (res.ok) {
          msg.textContent = 'Check your inbox to confirm.';
          msg.classList.add('success');
          input.value = '';
        } else {
          msg.textContent = data.error || 'Something went wrong.';
          msg.classList.add('error');
        }
      } catch {
        msg.textContent = 'Something went wrong.';
        msg.classList.add('error');
      }

      btn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    });
  });
</script>

<style>
  .newsletter-signup {
    background: var(--color-surface-01);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    margin-top: var(--space-12);
  }

  .newsletter-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .newsletter-label {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-green-500);
    margin: 0;
  }

  .newsletter-copy {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .newsletter-form {
    margin-top: var(--space-2);
  }

  .newsletter-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .newsletter-input {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-primary);
    background: var(--color-surface-02);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-sm);
    padding: 9px 12px;
    outline: none;
    transition: border-color var(--duration-quick) var(--easing-smooth);
  }

  .newsletter-input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter-input:focus {
    border-color: var(--color-green-500);
  }

  .newsletter-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--color-green-500);
    color: var(--color-on-accent);
    padding: 9px 16px;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background var(--duration-quick) var(--easing-smooth),
      transform var(--duration-quick) var(--easing-spring);
  }

  .newsletter-btn:hover:not(:disabled) {
    background: var(--color-green-400);
    transform: translateY(-1px);
  }

  .newsletter-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-msg {
    font-family: var(--font-mono);
    font-size: 13px;
    margin: var(--space-2) 0 0 0;
    min-height: 20px;
  }

  .newsletter-msg.success {
    color: var(--color-green-500);
  }

  .newsletter-msg.error {
    color: var(--color-error);
  }

  .newsletter-consent {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: var(--space-2) 0 0 0;
  }

  .newsletter-consent a {
    color: var(--color-text-muted);
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .newsletter-row {
      flex-direction: column;
    }
  }
</style>
