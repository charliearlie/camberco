---
import '../../styles/tokens.css';
import '../../styles/editor.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Camber Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#000000" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Google Fonts: JetBrains Mono + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Admin top bar -->
    <header class="admin-topbar">
      <a href="/admin" class="admin-topbar-logo">$ camber admin</a>
      <nav class="admin-topbar-actions">
        <a href="/admin/enquiries" class="admin-topbar-link">enquiries</a>
        <a href="/admin/settings" class="admin-topbar-link">settings</a>
        <a href="/" class="admin-topbar-link">← back to site</a>
      </nav>
    </header>

    <!-- Page content -->
    <slot />
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--color-base);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    font-size: var(--type-body);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
  }
</style>
